
MODULE erdos421_solution

-- ---------------------------------------------------------------------------
-- Definitions
-- ---------------------------------------------------------------------------

DEFINITION positive_sequence:
  A sequence d is an increasing positive-integer sequence when
  d_1 < d_2 < ... and d_i in N_{>0} for every i.

DEFINITION natural_density_one:
  A set A subset N has natural density one when
  |A cap [1,N]| / N -> 1 as N -> infinity.

DEFINITION interval_product:
  For an increasing sequence d and positive indices u <= v,
  P_d(u,v) := product_{u <= i <= v} d_i.

DEFINITION distinct_consecutive_block_products:
  A sequence d has distinct consecutive-block products when
  P_d(u,v)=P_d(u',v') implies u=u' and v=v' for every finite index
  interval [u,v] and [u',v'].

DEFINITION erdos421_target:
  There exists an increasing positive-integer sequence d whose underlying set
  has natural density one and whose consecutive-block products are distinct.

DEFINITION prefix_greedy_sequence:
  Reject 1, accept 2, and start from the accepted set A={2}.
  For n=3,4,5,... in order, accept n iff adding n to A creates no equality
  between two distinct finite consecutive-block products of the enlarged
  accepted sequence.  Otherwise reject n.

DEFINITION rejected_count:
  R(N) := #{n <= N : n is rejected by prefix_greedy_sequence}.

DEFINITION empty_suffix_rejected_count:
  E_0(N) := #{n <= N : n is rejected by prefix_greedy_sequence and has a
  rejecting equality n=P_d(u,v) with an old consecutive accepted block}.
  This definition does not include the manually rejected initial value n=1
  unless such an old-block equality exists.

DEFINITION nonempty_suffix_rejected_count:
  R_+(N) := #{n <= N : n is rejected by prefix_greedy_sequence and has a
  rejecting equality
    P_d(u,v)=n*P_d(c,m)
  where P_d(c,m) is a nonempty suffix product of the accepted prefix before n}.

-- ---------------------------------------------------------------------------
-- Basic greedy reductions
-- ---------------------------------------------------------------------------

THEOREM prefix_greedy_product_uniqueness:
  GIVEN:
    - A is generated by prefix_greedy_sequence.
  CLAIM:
    Every finite stage of A has distinct consecutive-block products.

PROOF OF prefix_greedy_product_uniqueness:
  [1] HAVE the initial stage A={2} has distinct consecutive-block products.
      BY there is only one nonempty accepted interval and its product is 2.
  [2] HAVE if a finite stage has distinct consecutive-block products and n is
      rejected, then the next finite stage has distinct consecutive-block
      products.
      BY rejection leaves the accepted sequence unchanged.
  [3] HAVE if a finite stage has distinct consecutive-block products and n is
      accepted, then the next finite stage has distinct consecutive-block
      products.
      BY the acceptance rule tests the enlarged sequence and accepts n only
      when no equality between two distinct finite consecutive-block products
      is present after adjoining n.
  [4] SHOW every finite stage has distinct consecutive-block products.
      BY induction over candidates n>=3 using [1], [2], and [3].
  QED BY [4].

THEOREM prefix_greedy_rejection_witness_split:
  GIVEN:
    - n>=3 is rejected by prefix_greedy_sequence.
    - d_1<...<d_m is the accepted prefix before testing n.
  CLAIM:
    There is an old consecutive accepted block product P and a suffix product
    S of the accepted prefix, possibly the empty suffix S=1, such that
      P=n*S.
    Consequently every rejected n>=3 is counted by at least one of the
    empty-suffix or nonempty-suffix rejection families.  Equivalently, after
    choosing any rejecting witness one obtains either an empty-suffix or a
    nonempty-suffix label for that witness; no disjointness of the two
    existence-defined endpoint families is required.

PROOF OF prefix_greedy_rejection_witness_split:
  [1] HAVE the old accepted prefix has distinct consecutive-block products.
      BY prefix_greedy_product_uniqueness applied to the prefix before n.
  [2] HAVE after adjoining n, every new consecutive-block product is n*S,
      where S is a suffix product of the old accepted prefix, including the
      empty suffix S=1.
      BY n is appended at the end of the accepted prefix, so a new consecutive
         block must end at n and is n times the old suffix immediately before
         it.
  [3] HAVE two distinct new blocks cannot have equal products.
      BY if n*S=n*S' then S=S'; suffix products of a positive sequence with
         all terms >1 determine the suffix, since extending a suffix to the
         left strictly multiplies its product by an integer >1.
  [4] HAVE rejection of n gives a collision between one old block and one new
      block.
      BY rejection means that the enlarged sequence has an equality between
         two distinct consecutive-block products; [1] rules out old-old
         collisions and [3] rules out new-new collisions.
  [5] SHOW there is an old consecutive accepted block product P and an old
      suffix product S, possibly empty, with P=n*S.
      BY [2] and [4].
  [6] SHOW the stated empty/nonempty covering.
      BY if S=1 the witness is an empty-suffix witness, while if S>1 the
         suffix is nonempty because all old accepted terms are >1.
  QED BY [5] AND [6].

THEOREM prefix_greedy_density_reduction:
  GIVEN:
    - R(N)=o(N).
  CLAIM:
    The accepted set of prefix_greedy_sequence has natural density one.

PROOF OF prefix_greedy_density_reduction:
  [1] HAVE #{accepted n <= N}=N-R(N).
      BY each integer n<=N is either accepted or rejected by the construction,
      and the two alternatives are disjoint.
  [2] HAVE #{accepted n <= N}/N = 1 - R(N)/N.
      BY divide [1] by N.
  [3] HAVE R(N)/N -> 0.
      BY the hypothesis R(N)=o(N).
  [4] SHOW #{accepted n <= N}/N -> 1.
      BY [2] and [3].
  QED BY [4].

THEOREM prefix_greedy_route_solves_erdos421:
  GIVEN:
    - R(N)=o(N) for prefix_greedy_sequence.
  CLAIM:
    erdos421_target holds.

PROOF OF prefix_greedy_route_solves_erdos421:
  [1] HAVE the accepted prefix-greedy set has natural density one.
      BY prefix_greedy_density_reduction applied to the hypothesis R(N)=o(N).
  [2] HAVE the accepted prefix-greedy sequence has distinct consecutive-block
      products.
      BY prefix_greedy_product_uniqueness.
  [3] SHOW erdos421_target holds.
      BY enumerate the accepted set increasingly and combine [1] with [2].
  QED BY [3].

THEOREM length_at_least_two_block_products_sparse:
  GIVEN:
    - d_1<d_2<... is any increasing sequence of positive integers with d_1>=2.
  CLAIM:
    The number of values <=N that occur as a consecutive block product
    P_d(u,v) with v-u+1>=2 is o(N).

PROOF OF length_at_least_two_block_products_sparse:
  [1] HAVE d_i>=i+1 for every index i.
      BY d_1>=2 and the sequence is strictly increasing in positive integers.
  [2] HAVE for a fixed length l>=2, the number of length-l consecutive
      products at most N is at most N^(1/l).
      BY if the block starts at index i, its product is at least (i+1)^l by
         [1], so i+1<=N^(1/l).
  [3] HAVE no length l>log_2 N can produce a product at most N.
      BY every term is at least 2, so every length-l product is at least 2^l.
  [4] HAVE the number of length-at-least-two block-product values <=N is at most
        sum_{2<=l<=log_2 N} N^(1/l)
        = O(N^(1/2)log N)=o(N).
      BY [2] and [3], with a union bound over lengths.
  [5] SHOW the claimed sparsity.
      BY [4].
  QED BY [5].

THEOREM empty_suffix_rejections_density_zero:
  GIVEN:
    - A is generated by prefix_greedy_sequence.
  CLAIM:
    The number of empty-suffix rejections n<=N is o(N).

PROOF OF empty_suffix_rejections_density_zero:
  [1] HAVE an empty-suffix rejection n is an old consecutive-block product of
      length at least 2.
      BY the empty suffix product is 1, so the rejecting equality is
         n=P_d(u,v); length 1 would imply n is an old accepted term, impossible
         for the current candidate.
  [2] HAVE d_i>=i+1 for every accepted index i.
      BY the accepted sequence starts with d_1=2 and is strictly increasing in
         positive integers.
  [3] HAVE the empty-suffix endpoint set is contained in the length-at-least-two
      block-product value set of the accepted sequence.
      BY [1].
  [4] SHOW E_0(N)=o(N).
      BY [2], [3], and length_at_least_two_block_products_sparse.
  QED BY [4].

THEOREM active_smooth_number_decay:
  GIVEN:
    - E>0, D>1, and M>0 are fixed constants.
    - Psi(X,Y) denotes the number of positive integers n<=X with
      P^+(n)<=Y.
    - Chebyshev's upper prime-counting bound pi(t)<<t/log t holds.
  CLAIM:
    (a) Psi(X,(log X)^E)=o(X).
    (b) With Y_X=exp(log X/(loglog X)^D),
        Psi(2X,Y_X)=o(X/(log X)^M).

PROOF OF active_smooth_number_decay:
  [1] HAVE for 1/2<=sigma<1 and Y>=3,
        Psi(X,Y) <= X^sigma product_{p<=Y}(1-p^(-sigma))^(-1).
      BY Rankin's trick applied to X^sigma n^(-sigma)>=1 for n<=X and to
         the Euler product over prime powers supported on primes p<=Y.
  [2] HAVE for sigma=1-eta with 0<eta<=1/2,
        log product_{p<=Y}(1-p^(-sigma))^(-1)
          <= C loglog(3Y) + C Y^eta/(eta log Y).
      BY log(1-u)^(-1)<<u for p^(-sigma)<=2^(-1/2), Chebyshev's upper bound
         pi(t)<<t/log t, and partial summation for
         sum_{p<=Y} p^(-1+eta): explicitly,
         sum_{p<=Y} p^(-1+eta)
           <= pi(Y)Y^(-1+eta)
              +(1-eta) int_2^Y pi(t)t^(-2+eta)dt
           << Y^eta/log Y + int_2^Y t^(-1+eta)/log t dt.
         With s=log t, the integral is int_{log 2}^{log Y} e^(eta s)/s ds.
         Splitting at s=1/eta gives O(loglog(3Y)) for the lower part and
         O(Y^eta/(eta log Y)) for the upper part.
  [3] HAVE Psi(X,(log X)^E)=o(X).
      BY choose fixed sigma in (0,1) with E(1-sigma)<1; then [1] and [2]
         give Psi(X,(log X)^E)<=X^sigma exp(o(log X))=o(X).
  [4] HAVE with L=log X, L_2=loglog X, u=(L_2)^D, and
        Y_X=exp(L/u), one has Psi(2X,Y_X)=o(X/(log X)^M).
      BY apply [1] and [2] with X replaced by 2X and with
         eta=(log u)/(2log Y_X), which is in (0,1/2] for all sufficiently
         large X.  The harmless factor 2 in 2X is absorbed into constants.
         Then eta log X=(1/2)u log u and Y_X^eta=sqrt(u), so the
         Euler-product exponent in [2] is
         O(loglog Y_X)+O(sqrt(u)/log u)=O(loglog X)+O(sqrt(u)/log u)
         =o(u log u).  Hence
         Psi(2X,Y_X)<=2X exp(-Omega(u log u)).  Because D>1,
         (u log u)/loglog X -> infinity, so exp(-Omega(u log u)) is
         o((log X)^(-M)) for every fixed M.
  [5] SHOW (a) and (b).
      BY [3] and [4].
  QED BY [5].

THEOREM actual_block_uniqueness_and_suffix_product_monotonicity:
  GIVEN:
    - A is any strictly increasing accepted set of positive integers.
  CLAIM:
    (a) For fixed accepted endpoint x and fixed length ell, there is at most
        one actual consecutive accepted block of length ell ending at x.
    (b) For fixed r, the function
          F_r(n)=n*(product of the last r accepted predecessors before n)
        is strictly increasing in n on the candidates for which it is defined.

PROOF OF actual_block_uniqueness_and_suffix_product_monotonicity:
  [1] HAVE (a).
      BY x has at most one accepted index in the strictly increasing accepted
         sequence, and a length ell block ending at that index is determined.
  [2] CONSIDER n_1<n_2 where both F_r(n_1) and F_r(n_2) are defined.
      BY to prove strict monotonicity it suffices to compare arbitrary
         candidates n_1<n_2 in the domain of F_r.
  [3] HAVE each coordinate of the r-tuple of last accepted predecessors before
      n_1 is <= the corresponding coordinate of the r-tuple before n_2.
      BY the accepted set below n_1 is a subset of the accepted set below n_2,
         and both ordered predecessor tuples are the top r elements of those
         nested sets.
  [4] HAVE product(last r predecessors before n_1)
        <= product(last r predecessors before n_2).
      BY [3] and positivity.
  [5] HAVE F_r(n_1)<F_r(n_2).
      BY n_1<n_2 and [4], with all products positive.
  [6] SHOW (a) and (b).
      BY [1] and [5].
  QED BY [6].

THEOREM overlap_cancelled_witness_and_prime_gap_localization:
  GIVEN:
    - n is a nonempty-suffix prefix-greedy rejection and is not charged to the
      empty-suffix rejection family.
    - d_1<...<d_m are the accepted terms before n.
  CLAIM:
    There is a rejecting witness
      product_{t=u}^v d_t = n product_{t=c}^m d_t
    with v<c<=m.  The right side uses the final suffix [c,m] of the accepted
    prefix before n, so if r=m-c+1 then those suffix terms are exactly the last
    r accepted predecessors before n.  Moreover, if q is the previous prime
    below n and n=q+h, then the right suffix begins after q and has length
    r<=h-1.

PROOF OF overlap_cancelled_witness_and_prime_gap_localization:
  [1] HAVE n has a rejecting equality
        product_{t=a}^b d_t = n product_{t=c}^m d_t
      with c<=m.
      BY nonempty-suffix rejection means n times a nonempty suffix product
         equals an old consecutive-block product.
  [2] HAVE the old block cannot be wholly contained in the suffix [c,m].
      BY then product_{t=a}^b d_t <= product_{t=c}^m d_t
         < n product_{t=c}^m d_t, contradicting [1].
  [3] HAVE if the old block overlaps [c,m] from the left, cancelling the common
      contiguous overlap preserves a product equality with the old block left
      of the remaining suffix, unless the suffix is exhausted.
      BY since the suffix is the final interval [c,m] and the old block
         [a,b] is not wholly contained in it by [2], the only overlapping case
         is a<c<=b<=m.  Cancelling the common interval [c,b] divides both sides
         of [1] by the same positive product and leaves
           product_{t=a}^{c-1} d_t = n product_{t=b+1}^{m} d_t.
         If b<m, the remaining right side is the final nonempty suffix
         [b+1,m] and the remaining old block is strictly to its left; if b=m,
         the suffix is exhausted.
  [4] HAVE if cancellation exhausts the suffix, then n is an old consecutive
      block product and the endpoint is an empty-suffix rejection.
      BY the remaining equality is product_{old remaining block}=n.
  [5] HAVE there is a nonempty remaining suffix with witness
        product_{t=u}^v d_t = n product_{t=c}^m d_t
      and v<c<=m.
      BY if the original old block is disjoint from the suffix, then b<c and
         the original witness already has the required form.  Otherwise use
         [3].  The exhausted-suffix alternative is ruled out by [4] and by the
         hypothesis that n is not charged to the empty-suffix family.
  [6] HAVE every prime p>2 is accepted by prefix_greedy_sequence.
      BY if p were rejected with empty suffix, p would be an old product of
         accepted terms all <p; length one would make p an old accepted term
         and length at least two is composite, both impossible.  If p were
         rejected with nonempty suffix, the new right block p times an old
         suffix product would be divisible by p.  The colliding old block uses
         only accepted terms from the prefix before p, hence all its factors are
         positive integers <p and none is divisible by the prime p.  Thus the
         old product is not divisible by p, a contradiction.
  [7] HAVE the right suffix in [5] contains no prime.
      BY if a prime p occurred in the suffix, then p is accepted by [6] and
         every left factor in [5] lies at an earlier accepted index than that
         suffix occurrence of p, hence is <p.  Thus the left product is not
         divisible by p while the right product is.
  [8] HAVE if q is the previous prime below n, then q is accepted and lies in
      the accepted prefix before n.
      BY if q=2 this is the initial accepted term; if q>2 use [6].  In both
         cases q<n, so q lies in the accepted prefix before n.
  [9] HAVE the suffix in [5] begins after q.
      BY otherwise the consecutive accepted suffix ending at d_m would contain
         the accepted term q, contradicting [7].
  [10] HAVE if n=q+h, then the suffix length r satisfies r<=h-1.
      BY all suffix terms are accepted integers strictly between q and n, and
         there are only h-1 integers in that open interval.
  [11] HAVE the suffix terms in [5] are exactly the last r accepted
       predecessors before n.
       BY [5] is a final suffix [c,m] of the accepted prefix before n.
  [12] SHOW the claimed witness and final-gap localization.
       BY [5], [9], [10], and [11].
  QED BY [12].

LEMMA primitive_line_factor_subpower_height:
  GIVEN:
    - X is sufficiently large.
    - G(A,R) is a primitive nonzero polynomial in Z[A,R] of total degree
      m with m^2=o(log X) and coefficient height H(G)=exp(o(log X)).
    - L(A,R)=alpha A + beta R + gamma is a primitive integer line factor of
      G over Q.
  CLAIM:
    (a) max(|alpha|,|beta|,|gamma|) <= exp(O(m log m)) H(G).
    (b) max(|alpha|,|beta|,|gamma|)=X^{o(1)}.

PROOF OF primitive_line_factor_subpower_height:
  [1] HAVE after homogenizing G to total degree m by
        G^h(A,R,W)=W^m G(A/W,R/W),
      the form L^h(A,R,W)=alpha A+beta R+gamma W is a primitive homogeneous
      linear factor of G^h.
      BY Gauss's lemma and the homogenization/divisibility facts stated in the
         header.
  [2] HAVE H(G^h)=H(G).
      BY homogenization only reindexes the nonzero coefficients of G.
  [3] HAVE H(L^h)=max(|alpha|,|beta|,|gamma|).
      BY L^h is linear.
  [4] CONSIDER a permutation of the homogeneous variables for which
      L^h becomes aU+bV+cW with |c|=H(L^h).
      BY choose a variable whose coefficient has maximum absolute value.
  [5] HAVE the permuted homogeneous polynomial F(U,V,W) still has degree m
      and height H(G).
      BY variable permutation preserves degree and coefficient height, and
         by [2].
  [6] HAVE P(U,V):=F(U,V,1) is a nonzero integer polynomial of degree at
      most m and height H(P)<=H(G).
      BY dehomogenizing a homogeneous degree-m polynomial at W=1 gives one
         distinct affine monomial U^i V^j for each homogeneous monomial
         U^i V^j W^(m-i-j).
  [7] HAVE P(U,V) is divisible in Z[U,V] by aU+bV+c.
      BY [1], [4], Gauss's lemma, and the dehomogenization/divisibility facts
         stated in the header.
  [8] HAVE if H(L^h)>1, then there is an integer t with 0<=t<=m+1 such
      that a+bt != 0 and the cofactor Q(U,V) in P=(aU+bV+c)Q has
      Q(Z,tZ) nonzero.
      BY if a=b=0, then primitivity of aU+bV+cW gives |c|=1 and hence
         H(L^h)=1; otherwise Q is a nonzero polynomial of degree at most
         m-1.  Write Q as a sum of homogeneous parts Q_j(U,V).  Since Q is
         nonzero, some Q_j is nonzero with j<=m-1; if Q(Z,tZ) is identically
         zero, then Q_j(1,t)=0 for this nonzero one-variable polynomial of
         degree at most j.  Thus there are at most m-1 slopes with
         Q(Z,tZ)=0 identically.  The condition a+bt=0 excludes at most one
         further integer slope, while the interval 0<=t<=m+1 contains m+2
         integers, so a permissible t exists.
  [9] HAVE if H(L^h)>1 and t is chosen as in [8], then
      P_t(Z):=P(Z,tZ) is a nonzero one-variable integer polynomial of
      degree at most m and divisible by (a+bt)Z+c.
      BY [7] and [8].
  [10] HAVE if H(L^h)>1 and t is chosen as in [8], then
       ||P_t||_2 <= exp(O(m log m)) H(G).
       BY each coefficient of P(Z,tZ) is a sum of at most m+1 coefficients
          of P, each multiplied by t^j with 0<=j<=m and t<=m+1; then use
          [6] and the fact that P_t has at most m+1 coefficients.
  [11] HAVE if H(L^h)>1 and t is chosen as in [8], then
       max(|a+bt|,|c|) <= exp(O(m log m)) H(G).
       BY apply Mignotte's one-variable factor inequality with
          f(Z)=(a+bt)Z+c, g(Z)=P_t(Z), and d=m.  Step [9] gives that g is a
          multiple of f in Z[Z], with deg f=1 and deg g<=m; also
          ||f||_infty=max(|a+bt|,|c|).  Thus
          max(|a+bt|,|c|)<=2^m ||P_t||_2, and [10] absorbs 2^m into
          exp(O(m log m))H(G).
  [12] HAVE H(L^h) <= exp(O(m log m)) H(G).
       BY if H(L^h)=1 this is immediate; otherwise choose t by [8] and use
          [4] and [11], since |c|=H(L^h).
  [13] SHOW (a) and (b).
      BY [3], [12], m log m=O(m^2), m^2=o(log X), and
         H(G)=exp(o(log X)).
  QED BY [13].

LEMMA nonabsolute_q_irreducible_factor_rational_point_bound:
  GIVEN:
    - H(A,R) in Z[A,R] is primitive, squarefree, Q-irreducible, not absolutely
      irreducible, and has total degree d>=2.
  CLAIM:
    The affine rational point set {P in Q^2 : H(P)=0} has cardinality at most
    d^2.

PROOF OF nonabsolute_q_irreducible_factor_rational_point_bound:
  [1] HAVE over Qbar, H is a product of at least two distinct absolutely
      irreducible Galois-conjugate factors H_1,...,H_t.
      BY the elementary algebraic facts in the header: Q-irreducibility makes
         the absolute factors one Galois orbit, nonabsolute irreducibility gives
         t>=2, and squarefreeness makes the factors distinct.
  [2] HAVE every rational point P with H(P)=0 lies on every factor H_j=0.
      BY H(P)=0 over Qbar implies H_i(P)=0 for some factor H_i.  Since P has
         rational coordinates, applying each Galois automorphism in the orbit of
         H_i gives H_j(P)=0 for every conjugate factor H_j.
  [3] HAVE the common zero set of any two distinct factors H_i,H_j has at most
      d^2 affine points over Qbar.
      BY distinct absolutely irreducible factors have no common component, and
         the Bezout fact in the header bounds the number of common affine points
         by deg(H_i)deg(H_j)<=d^2.
  [4] SHOW the rational point set has cardinality at most d^2.
      BY [1] choose two distinct factors and use [2] and [3].
  QED BY [4].

LEMMA polylog_auxiliary_interpolation_height:
  GIVEN:
    - X is sufficiently large.
    - K>=1 and m=ceil(4sqrt(K)).
    - Z is a set of K distinct integer points in the plane with coordinates
      bounded in absolute value by (log X)^B0 for a fixed constant B0.
    - K loglog X=o(log X).
  CLAIM:
    There is a nonzero nonconstant primitive polynomial G(A,R) in Z[A,R] of
    total degree at most m, height exp(O(m loglog X)), vanishing on all points
    of Z, with the first nonzero coefficient positive under the fixed monomial
    order.

PROOF OF polylog_auxiliary_interpolation_height:
  [1] HAVE the number N_m of monomials A^u R^v with u+v<=m satisfies
      N_m=(m+1)(m+2)/2>2K for all sufficiently large X.
      BY m=ceil(4sqrt(K)) and K>=1.
  [2] HAVE every entry of the K by N_m evaluation matrix on Z has absolute
      value at most H_0:=exp(O(m loglog X)).
      BY each coordinate of a point of Z has size at most (log X)^B0 and
         every monomial has total degree at most m.
  [3] HAVE there is a nonzero integer coefficient vector c in the kernel of
      this evaluation matrix with ||c||_infty<=exp(O(m loglog X)).
      BY elementary pigeonhole: compare coefficient vectors in [0,Q)^(N_m)
         under the K evaluation forms.  Their images have at most
         (2N_m H_0 Q+1)^K possible values.  Choose
         Q>=(3N_m H_0)^(K/(N_m-K))+1.  Since N_m>2K, the exponent
         K/(N_m-K)<1, and log N_m=O(log(m+1))=O(m)=O(m loglog X), so
         Q=exp(O(m loglog X)).  Two coefficient vectors have the same image,
         and their nonzero difference is the required kernel vector.
  [4] HAVE the polynomial G built from c has total degree at most m, height
      exp(O(m loglog X)), and vanishes on every point of Z.
      BY [3] and the definition of the evaluation matrix.
  [5] HAVE after dividing the coefficient vector of G by the gcd of its
      coefficients and, if necessary, multiplying by -1, G is primitive, has
      first nonzero coefficient positive, keeps the same degree and vanishing
      properties, and still has height exp(O(m loglog X)).
      BY the gcd division can only decrease coefficient sizes and does not
         change the zero set; the sign change does not affect vanishing or
         height.
  [6] HAVE G is not a nonzero constant.
      BY K>=1 and G vanishes at a point of Z.
  [7] SHOW the claimed polynomial exists.
      BY [4], [5], and [6].
  QED BY [7].

THEOREM general_shifted_crt_slab_count:
  GIVEN:
    - Fixed constants A,B,D>0 and a dyadic shell X<n<=2X.
    - Integral localized data
        n=q+h, 1<=h<=(log X)^A, T_X=(log X)^B,
        x=q^theta+O(T_X), D_0=q-x>0,
        0<theta<1,
        1/(log X)^B <= 1-theta <= B loglog X/log X.
      Here n,q,h,x,D_0 are integers and the implicit constant in O(T_X) is
      uniform after the fixed ambient constants and the localization scheme are
      fixed.
    - The localized parameter tuples, including h, theta=b/(b+s), and K, form
      a set P_X with the explicit subpower bound:
      for every epsilon>0 there is X_epsilon such that
        |P_X|<=X^epsilon
      for all X>=X_epsilon.
    - Y_X=exp(log X/(loglog X)^D).
    - K is a positive integer and each endpoint carries K distinct local slab
      points z_i=(a_i,r_i), with integer coordinates satisfying
      0<=a_i<T_X and |r_i|<=C_z(T_X+(\log X)^A) for a constant C_z fixed by
      the ambient constants, and distinct prime labels p_i>Y_X satisfying
        p_i | x-a_i
        and p_i | D_0+r_i.
    - K loglog X=o(log X) and
        (K log Y_X)/(sqrt(K)log X) -> infinity.
  CLAIM:
    The number of such endpoints in the dyadic shell is o(X).

PROOF OF general_shifted_crt_slab_count:
  [1] CONSIDER the localized parameter tuple and one retained K-set of local
      points Z={z_1,...,z_K}.
      BY the theorem is proved after fixing one admissible localized parameter
         tuple and one deterministic retained K-set of local coordinates, then
         summing over the parameter set P_X from the hypothesis.  The prime
         labels are not fixed or enumerated here: for each endpoint they are
         only witnesses to the congruences in the hypotheses and will be used
         after G is fixed to force divisibility of G(x,-D_0).  Thus an
         endpoint carrying more than one admissible retained K-set is safely
         overcounted by the later sum over all coordinate sets.
  [2] HAVE the number of possible retained sets Z is X^{o(1)}.
      BY all z_i lie in a fixed-polylogarithmic box of side
         O(T_X+(\log X)^A), so
         the ambient number of local points is M_box=(log X)^{O(1)}.  If
         K>M_box then there are no retained K-sets.  Otherwise
         binom(M_box,K)<=M_box^K=exp(O(K loglog X))=X^{o(1)}, using
         K loglog X=o(log X).
  [3] HAVE with m=ceil(4sqrt(K)), there is a canonically chosen nonzero
      nonconstant integer polynomial G(A,R) of total degree <=m, height
      exp(O(m loglog X)), vanishing on all points of Z.
      BY polylog_auxiliary_interpolation_height gives at least one such
         polynomial, since all retained local points lie in a
         fixed-polylogarithmic coordinate box and K loglog X=o(log X).  Among
         all primitive coefficient vectors with first nonzero coefficient
         positive and height within the stated bound, choose the
         lexicographically least one.  Thus G depends only on the fixed
         localized parameters and retained local coordinate set Z, not on the
         endpoint's prime labels.
  [4] HAVE for every i,
        (x,-D_0) == (a_i,r_i) mod p_i.
      BY p_i|x-a_i and p_i|D_0+r_i.
  [5] HAVE prod_i p_i divides G(x,-D_0).
      BY G was chosen from the coordinate set Z, so G(a_i,r_i)=0 for every
         retained point; [4] gives (x,-D_0)==(a_i,r_i) modulo the corresponding
         endpoint-specific prime p_i; and the labels p_i are distinct primes.
  [6] HAVE if G(x,-D_0) is nonzero, then
        log |G(x,-D_0)| <= O(sqrt(K)log X).
      BY deg G=O(sqrt(K)), height exp(O(sqrt(K)loglog X)), and
         |x|,|D_0|=O(X).  More explicitly, G has O(m^2)=O(K) monomials,
         every monomial value at (x,-D_0) has absolute value at most
         (C X)^m, and each coefficient has size exp(O(m loglog X)).  Thus
         |G(x,-D_0)|<=O(K)exp(O(m loglog X))(C X)^m, whose logarithm is
         O(m log X)=O(sqrt(K)log X).
  [7] HAVE log(prod_i p_i) >= K log Y_X.
      BY each p_i>Y_X.
  [8] HAVE G(x,-D_0)=0.
      BY [5], [6], [7], and
         (K log Y_X)/(sqrt(K)log X) -> infinity: the implicit constant in [6]
         is fixed after the fixed ambient constants are chosen, so for all
         sufficiently large X the divisor prod_i p_i is larger than any possible
         nonzero value |G(x,-D_0)|.
  [9] HAVE all endpoints are contained in N_curve(X)=X^{o(1)} auxiliary plane
      curves G(A,R)=0, each of degree m=ceil(4sqrt(K))=X^{o(1)} and height
      exp(O(m loglog X)).
      BY the localized parameter tuples have |P_X|=X^{o(1)} choices by
         hypothesis, and [2] gives exp(O(K loglog X))=X^{o(1)} possible retained
         coordinate sets for each parameter tuple.  In epsilon form: after
         constants are fixed, for every epsilon>0 and all sufficiently large X,
         the tuple count is at most X^(epsilon/2) and the retained-set count is
         at most X^(epsilon/2), hence the total number of canonical curves is
         at most X^epsilon.  Step [3] assigns one canonical auxiliary curve to
         each such pair, and [8] places every counted endpoint on its assigned
         curve.
  [10] HAVE nonlinear components contribute o(X) endpoints.
      BY [9] and the external CCDN affine-curve theorem applied componentwise
         after replacing each auxiliary polynomial by its primitive part and
         then by its squarefree radical: removing content does not change the
         zero set, and if G(x,-D_0)=0 then at least one primitive squarefree
         Q-irreducible factor H still vanishes at (x,-D_0).  These factors split
         into exactly three cases: primitive Q-line factors, absolutely
         irreducible nonlinear factors, and Q-irreducible but nonabsolute
         factors.  Primitive Q-line factors are excluded from this count and
         treated below.  If H is absolutely irreducible and deg H=d>=2, it
         defines an integral affine curve over Q.  The global coordinates satisfy
         |x|,|D_0|<=C X for a fixed C, so CCDN applies with height parameter
         B_box=C X and gives
         O(d^3 (C X)^(1/d)(log(C X)+d)) <= X^(1/2+o(1)) points in the O(X) box.
         More explicitly, the squarefree factors of one auxiliary polynomial
         have total degree at most deg G=m=X^{o(1)}; since every nonlinear factor
         counted here has d>=2, summing
         d^3 (C X)^(1/d)(log(C X)+d) over those factors is still X^(1/2+o(1)).
         If H is not absolutely irreducible, then
         nonabsolute_q_irreducible_factor_rational_point_bound gives O(d^2)
         rational points on that Q-factor.  The sum of these O(d^2) bounds over
         nonabsolute factors is X^{o(1)}, because the number of factors is at
         most m and their total degree is at most m.  Thus the
         non-Q-line part of one auxiliary curve contributes X^(1/2+o(1)) integer
         points.  Multiplication by the N_curve(X)=X^{o(1)} curves from [9] still
         gives X^(1/2+o(1))=o(X) points.  The localized parameter tuple assigned
         to each auxiliary curve already fixes h; for fixed h each integer point
         (x,-D_0) determines q=x+D_0 and n=q+h, so this is also an o(X) endpoint
         bound.
  [11] HAVE if alpha A + beta R + gamma = 0 is a primitive line factor of the
       primitive squarefree part of G, then
       max(|alpha|,|beta|,|gamma|)=X^{o(1)}.
      BY such a line factor is also a Q-factor of the primitive part of the
         original auxiliary polynomial from [3].  Apply
         primitive_line_factor_subpower_height to that primitive part: its
         degree is m=O(sqrt(K)), its height is at most
         exp(O(sqrt(K)loglog X))=exp(o(log X)), and
         m^2=O(K)=o(log X) since K loglog X=o(log X).  The explicit bound from
         that lemma is
         exp(O(m log m))H(G)=exp(O(m log m+m loglog X)).
  [12] HAVE at R=-D_0=x-q,
        (alpha+beta)x - beta q + gamma = 0.
       BY substituting the global point into the line.
  [13] HAVE q>=X/2 and x>=q/(log X)^{O(B)} for all sufficiently large X.
       BY n=q+h lies in (X,2X] with h<=(log X)^A, and
          x=q^theta+O(T_X) with
          1-theta<=B loglog X/log X, so
          q^theta=q exp(-(1-theta)log q)>=q/(log X)^{O(B)} and
          the O(T_X) error is negligible compared with this lower bound.
  [14] HAVE beta!=0 and alpha+beta!=0 for all sufficiently large X.
       BY if beta=0, [12] forces x=X^{o(1)}, contradicting [13]; if
          alpha+beta=0, [12] forces q=X^{o(1)}, contradicting [13].
  [15] HAVE with
        F(q)=(alpha+beta)q^theta - beta q + gamma
        and E_X=M_X T_X, where
        M_X=exp(C_m m log m+C_h m loglog X) for sufficiently large absolute
        constants C_m,C_h depending only on the fixed ambient constants, one has
       |F(q)|<=E_X.
       BY [11], [12], and x=q^theta+O(T_X), since
          F(q)=(alpha+beta)(q^theta-x).  The line-height bound [11] gives
          |alpha+beta|<=exp(O(m log m+m loglog X)), uniformly for all primitive
          line factors of all canonical auxiliary curves in [9]; increasing
          C_m,C_h absorbs the fixed tube constant in the O(T_X) term.  Also
          M_X=exp(o(log X)) because m^2=O(K)=o(log X) and
          K loglog X=o(log X).
  [16] HAVE on the shell sublevel set |F(q)|<=E_X,
        |F'(q)| >= c |beta|(1-theta).
       BY if |F'(q)|<|beta|(1-theta)/4, write
          delta=F'(q).  Since
          F'(q)=(alpha+beta)theta q^(theta-1)-beta, one has
          (alpha+beta)q^theta=(beta+delta)q/theta.  Hence
          F(q)=beta q(1-theta)/theta + delta q/theta + gamma.
          For large X, theta>=1/2, so
          |delta|q/theta <= |beta|(1-theta)q/(4theta), and therefore
          |F(q)| >= (3/4)|beta|(1-theta)q/theta - |gamma|
                  >= c|beta|(1-theta)q-M_X
                  >= cX/(log X)^B-M_X
                  >> M_X T_X,
          using [11], [13], [14], |beta|>=1,
          1-theta>=(log X)^(-B), the fact that the same envelope M_X dominates
          |gamma| by [11] and the choice of C_m,C_h, and the fact that
          X/(log X)^B dominates M_X T_X because M_X=exp(o(log X)).
          This contradicts [15].
  [17] HAVE each primitive line factor and fixed localized parameter tuple
       contributes X^{o(1)} possible q.
       BY [14], F'(q)=(alpha+beta)theta q^(theta-1)-beta is monotone on q>0
          because 0<theta<1 and alpha+beta!=0, hence it has at most one zero q_0.
          Split the shell into the at most two intervals cut out by q_0.  On
          each side F is monotone, and by [16] every connected component of
          the sublevel set |F(q)|<=E_X has
          |F'|>=c|beta|(1-theta).  For any two points q_1<q_2 in one such
          component, the mean-value theorem gives
          c|beta|(1-theta)(q_2-q_1)<=|F(q_2)-F(q_1)|<=2E_X.  Taking suprema
          over q_1,q_2 in the component gives length at most
          2E_X/(c|beta|(1-theta)) per side, including components cut by the
          dyadic shell boundary.  There is at most one sublevel component on
          each monotonicity interval, and there are at most two such intervals.
          The number of integer q in a real interval of length L is at most
          L+1; hence the total number of integer q satisfying the shell
          condition and |F(q)|<=E_X is
          O(1+E_X/(|beta|(1-theta)))=X^{o(1)}.  Here |beta|>=1 by [14] and
          1-theta>=(log X)^(-B), while E_X=M_X T_X=X^{o(1)} by [15].
  [18] HAVE line components contribute o(X) endpoints.
       BY each canonical auxiliary curve in [9] has at most m=X^{o(1)}
          primitive line factors, and there are N_curve(X)=X^{o(1)} such curves.
          Each canonical curve is already attached to a fixed localized
          parameter tuple, including h.  Step [17] gives X^{o(1)} integer q
          values for each fixed line factor of that curve, with all shell
          boundary components already included.  Thus the total number of
          line-component pairs (curve,line,q) is
          N_curve(X)*m*X^{o(1)}=X^{o(1)}.  For fixed h, which belongs to the
          localized tuple attached to the curve, each counted q gives the
          unique endpoint n=q+h.  Hence all line components give X^{o(1)}=o(X)
          endpoints.
  [19] SHOW the total endpoint count is o(X).
       BY [10] and [18].
  QED BY [19].

THEOREM accepted_factor_smooth_deletion_count:
  GIVEN:
    - Fixed constants A,B,D>1 and C>0.
    - X<n<=2X is a dyadic shell, with
        G_X=(log X)^A,
        T_X=(log X)^B,
        Y_X=exp(log X/(loglog X)^D).
    - A deterministic chosen localized witness for n has left factors
        x-a_i with 0<=a_i<T_X,
      right suffix length r<=G_X, and left length ell<=(log X)^L for one
      fixed L; the right suffix is the final length-r suffix of the accepted
      prefix before n.
    - The localized witness has x<2X, hence every left factor x-a_i is <=2X.
    - active_smooth_number_decay gives Psi(2X,Y_X)=o(X/(log X)^M) for every
      fixed M.
  CLAIM:
    The number of shell endpoints whose chosen localized witness has an
    accepted left factor m=x-a_i with P^+(m)<=Y_X is o(X/(log X)^C).
    Moreover, after multiplying this endpoint family by one final-gap
    expansion factor G_X=(log X)^A, the expanded family is still
    o(X/(log X)^C).

PROOF OF accepted_factor_smooth_deletion_count:
  [1] HAVE for S_X={m<=2X : P^+(m)<=Y_X}, one has
      |S_X|=o(X/(log X)^M) for every fixed M.
      BY active_smooth_number_decay with the fixed parameter D.
  [2] HAVE for each m in S_X there are at most T_X possible values of x in a
      localized witness using m as a left factor.
      BY x=m+a_i with 0<=a_i<T_X.
  [3] HAVE for each fixed x and ell there is at most one actual accepted left
      block ending at x.
      BY actual_block_uniqueness_and_suffix_product_monotonicity.
  [4] HAVE for each fixed actual left block and fixed suffix length r there is
      at most one endpoint n in the shell.
      BY let P be the fixed product of the fixed actual left block.  For every
         endpoint counted with this left block and this r, the chosen localized
         witness gives
           P=n*(product of the last r accepted predecessors before n),
         because the localized suffix is exactly the final length-r suffix.
         The right side is the strictly increasing function F_r(n) from
         actual_block_uniqueness_and_suffix_product_monotonicity, so it can
         equal the fixed value P for at most one endpoint n.
  [5] HAVE the endpoint count is at most
        |S_X| * T_X * (log X)^L * G_X.
      BY use a union bound over the chosen smooth left factor m in S_X.  For
         each m, step [2] gives at most T_X possible old-left maxima x=m+a with
         0<=a<T_X.  For each such x and each ell<=(log X)^L, step [3] gives at
         most one actual accepted left block; if m is not in that block, this
         choice contributes no endpoint.  For each remaining block and each
         r<=G_X, step [4] gives at most one endpoint.  This already accounts for
         the possible position of m in the left block through the choice of
         x=m+a, so no extra factor ell is needed.
  [6] HAVE the endpoint count is o(X/(log X)^C).
      BY after the fixed constants A,B,C,L are chosen, apply [1] with any fixed
         M>C+A+B+L+1; then the fixed-polylogarithmic multiplier
         T_X*(log X)^L*G_X is at most (log X)^(A+B+L), leaving
         o(X/(log X)^C).
  [7] HAVE after one final-gap expansion by at most G_X, the expanded count is
      o(X/(log X)^C).
      BY before the expansion apply [1] with any fixed M>C+2A+B+L+1.  The
         endpoint count from [5] is then o(X/(log X)^(C+A)), and multiplying by
         the extra G_X=(log X)^A still leaves o(X/(log X)^C).
  [8] SHOW the claimed endpoint and expanded endpoint bounds.
      BY [6] and [7].
  QED BY [8].

THEOREM terminal_support_slab_extraction:
  GIVEN:
    - A surviving localized witness has product identity
        prod_{i=1}^ell (x-a_i)=prod_{j=1}^b(q+c_j),
      where n=q+h is included as the terminal value c=h, every c_j satisfies
      1<=c_j<=h, the terminal values q+c_j are distinct, and D_0=q-x>0.
    - The left factors x-a_i are distinct accepted terms, 0<=a_i<T_X,
      h<T_X, and Y_X>T_X+h.
    - Every accepted left factor x-a_i has a chosen prime
        p_i=P^+(x-a_i)>Y_X.
    - Lambda_X=ceil(log(3X)/log Y_X)+2.
    - x<q<2X and a_i+c_j<T_X+h.
  CLAIM:
    There are at least floor(ell/Lambda_X^2) distinct local slab points
      (a_i,r_i), r_i=a_i+c_i, with pairwise distinct r_i,
    hence with distinct local slab points, and with distinct prime labels
    p_i>Y_X satisfying
      p_i | x-a_i
      and p_i | D_0+r_i.

PROOF OF terminal_support_slab_extraction:
  [1] HAVE for every i, p_i divides one terminal value q+c_i with
      1<=c_i<=h.
      BY p_i divides the left product, hence the right product; if p_i|n then
         take c_i=h, otherwise p_i divides one accepted right-suffix factor.
  [2] HAVE the terminal value q+c_i in [1] is unique for each i.
      BY p_i>Y_X>h, while two distinct terminal values q+c and q+c' with
         1<=c,c'<=h differ by a nonzero integer of absolute value <p_i.
  [3] HAVE each label p_i occurs on at most one left factor and at most one
      terminal value.
      BY two localized left factors differ by less than T_X<p_i, and two
         terminal values differ by at most h<p_i.
  [4] HAVE a terminal value is incident to at most Lambda_X chosen labels.
      BY by [3], the chosen labels incident to a fixed terminal value are
         distinct primes.  Every terminal value is at most q+h=n<=2X<3X.  If
         it had t distinct prime factors exceeding Y_X, then their product
         would exceed Y_X^t and still divide the terminal value; hence
         Y_X^t<3X and t<=floor(log(3X)/log Y_X).  Thus it has at most
         ceil(log(3X)/log Y_X)+1<=Lambda_X distinct prime factors exceeding
         Y_X.  Only the one chosen label p_i=P^+(x-a_i) from each left factor is
         counted here; prime powers and unchosen prime factors can only increase
         multiplicity inside a terminal value, not the number of distinct chosen
         labels incident to it.
  [5] HAVE the incidence graph contains a matching of size at least
      floor(ell/Lambda_X).
      BY every left vertex has exactly one chosen label edge by [1] and the
         uniqueness in [2].  Each terminal vertex has degree at most Lambda_X
         by [4], so the ell left edges occupy at least ceil(ell/Lambda_X)
         terminal vertices, hence at least floor(ell/Lambda_X).  Select one
         incident edge over each occupied terminal
         vertex.  The selected terminal vertices are distinct by construction,
         and the selected left vertices are distinct because a left vertex has
         degree one and therefore cannot be incident to two different occupied
         terminals.  Thus the selected edges form a matching; by [3] their
         labels are distinct.
  [6] HAVE for each matched edge, with r_i=a_i+c_i, one has
      p_i | D_0+r_i.
      BY D_0+r_i=q-x+a_i+c_i=(q+c_i)-(x-a_i), and p_i divides both terms.
  [7] HAVE for a fixed local value rho, at most Lambda_X matched labels have
      r_i=rho.
      BY the matched labels are distinct primes by [5].  If r_i=rho, all such
         labels divide D_0+rho by [6].  Here D_0>0 and
         rho=a_i+c_i satisfies 0<rho<T_X+h, so D_0+rho is a positive integer;
         also D_0<q<2X and T_X+h=o(X), hence D_0+rho<3X for large X.  Therefore
         this integer has at most Lambda_X distinct prime factors >Y_X.
  [8] SHOW there are at least floor(ell/Lambda_X^2) distinct local slab
      points with distinct labels and the stated divisibilities.
      BY [3], [5], [6], and [7], selecting one representative matched edge for
         each distinct value of r_i; if M>=floor(ell/Lambda_X) matched edges
         remain and each r_i value supports at most Lambda_X of them, then
         the number of distinct r_i values is at least
         ceil(M/Lambda_X)>=floor(ell/Lambda_X^2).  The last inequality follows
         by writing ell=a Lambda_X^2+r with 0<=r<Lambda_X^2: then
         floor(ell/Lambda_X)>=a Lambda_X, so
         ceil(floor(ell/Lambda_X)/Lambda_X)>=a=floor(ell/Lambda_X^2).
         Distinct r_i give distinct local slab points, and the representatives
         are a subset of the matched edges, whose labels are already distinct
         by [5].
  QED BY [8].

LEMMA selberg_prime_rank_span_exception_count:
  GIVEN:
    - Selberg's consecutive-prime gap bound
        sum_{p_j<=2X} (p_{j+1}-p_j)^2 << X(log X)^3.
    - B>=1 is an integer and H>=1.
    - P_B(x) denotes the B-th previous prime below x when it exists.
  CLAIM:
    #{x<=2X : P_B(x) exists and x-P_B(x)>H}
      << B^2 X(log X)^3/H.

PROOF OF selberg_prime_rank_span_exception_count:
  [1] HAVE for x in [p_k,p_{k+1}), if P_B(x) exists then
        x-P_B(x) <= S_{k,B}^+:=p_{k+1}-p_{k-B}.
      BY if x>p_k, then P_B(x)=p_{k-B+1}; if x=p_k, the strict "below x"
         convention gives P_B(x)=p_{k-B}.  In both cases the B+1 consecutive
         prime gaps from p_{k-B} up to p_{k+1} cover the interval from
         P_B(x) to x.
  [2] HAVE the number of x in [p_k,p_{k+1}) with x-P_B(x)>H is at most
      S_{k,B}^+ when S_{k,B}^+>H, and is zero otherwise.
      BY [1] and the interval length bound p_{k+1}-p_k<=S_{k,B}^+.
  [3] HAVE the exceptional count is at most
        H^{-1} sum_{p_k<=2X} (S_{k,B}^+)^2.
      BY summing [2] over the prime intervals [p_k,p_{k+1}) which intersect
         [1,2X], equivalently over p_k<=2X.  The finitely many initial
         intervals for which P_B does not exist are ignored by the condition,
         and truncating the last interval at 2X only reduces the count.  Use
         S_{k,B}^+<=H^{-1}(S_{k,B}^+)^2 on the terms where S_{k,B}^+>H.
  [4] HAVE sum_{p_k<=2X} (S_{k,B}^+)^2
       <= (B+1)^2 sum_{p_j<=2X} (p_{j+1}-p_j)^2
       << B^2 sum_{p_j<=2X} (p_{j+1}-p_j)^2.
      BY Cauchy's inequality gives
         (S_{k,B}^+)^2 <= (B+1) sum_{j=k-B}^{k}
         (p_{j+1}-p_j)^2.  In the restricted sum p_k<=2X, each prime-gap
         square with p_j<=2X occurs in at most B+1 such sums.  The possible
         final gap with p_j<=2X<p_{j+1} is included in Selberg's indexed sum,
         while finite initial omissions only reduce the left side.  Since
         B>=1, (B+1)^2<<B^2.
  [5] SHOW the claimed bound.
      BY [3], [4], and Selberg's consecutive-prime gap bound.
  QED BY [5].

THEOREM localized_nonempty_witness_after_independent_tails:
  GIVEN:
    - A>3 is fixed.
    - C_0=10A, K_0=10A, E=30A, B=20A.
    - X is sufficiently large and X<n<=2X.
    - n is a nonempty-suffix prefix-greedy rejection not charged to the
      empty-suffix family.
    - Selberg's consecutive-prime gap bound holds, and
      active_smooth_number_decay is available for fixed-polylogarithmic
      smooth cutoffs.
  CLAIM:
    Fix the deterministic witness rule which, for each endpoint, takes the
    lexicographically first nonempty rejecting old-new equality, performs the
    overlap cancellation from overlap_cancelled_witness_and_prime_gap_localization,
    and then keeps the resulting nonempty left-block/final-suffix tuple.
    Outside o(X) shell endpoints, this chosen tuple is a witness
      prod_{i=1}^ell (x-a_i)=prod_{j=1}^b(q+c_j)
    with
      n=q+h, 2<=h<=(log X)^A,
      0<=a_i<T_X, 1<=c_j<=h, T_X=(log X)^B,
      b=r+1, ell=b+s, s>=1,
      r<=G_X=(log X)^A and ell<=D_X:=ceil((G_X+1)log_2(2X))+2
        <=(log X)^(A+2) for large X,
      the b-1 terminal factors other than n are the final length-r suffix of
      the accepted prefix before n,
      the left factors x-a_i are distinct accepted terms from the old left
        block, and the terminal values q+c_j are distinct, with n=q+h among
        them,
      b>=c_A log X/loglog X for c_A=1/(2K_0),
      x=q^(b/ell)+O(T_X),
      1/(log X)^B <= 1-b/ell <= B loglog X/log X,
      and x<q<2X.
    The localization discards only the following shell endpoint families, each
    bounded without using the target density theorem:
      h>G_X, contributing O(X(log X)^(3-A));
      x<=H_0, contributing o(X) by the smooth-number estimate;
      x-P_{D_X}(x)>H_0, contributing O(X(log X)^(4A+9-E));
      ell/(r+1)>=1+C_0 loglog X/log X, contributing
        O(X/(log X)^(3A-2));
      r<=R_X=floor(log X/(K_0 loglog X)), contributing
        O(X/(log X)^(4A-3));
      and, after R_X<r<=G_X, the families x-P_{B_r}(x)>H_r, whose total
        contribution is O(X log(G_X/R_X)/log X).

PROOF OF localized_nonempty_witness_after_independent_tails:
  [1] HAVE an overlap-cancelled witness
        product_{t=u}^v d_t = n product_{t=c}^m d_t
      with v<c<=m.  Put x=d_v, w=d_u, ell=v-u+1, and r=m-c+1.
      If q is the previous prime below n and n=q+h, then the right suffix
      begins after q, is the final length-r suffix of the accepted prefix, and
      r<=h-1.
      BY apply overlap_cancelled_witness_and_prime_gap_localization to the
         deterministic chosen nonempty rejecting equality.  The deterministic
         rule is used only to assign one tuple to each endpoint for counting;
         the overlap-cancellation and prime-gap conclusions hold for every
         admissible nonempty rejecting equality.
  [2] HAVE endpoints with h>(log X)^A contribute o(X).
      BY if h=n-q>G_X, then n lies in the consecutive-prime gap
         [q,p_next) of length g=p_next-q>G_X, where q is the previous prime
         below n.  For each such gap with left endpoint q<=2X, the number of
         endpoints n<=2X in the gap is at most g, and g<=g^2/G_X when
         g>G_X.  Summing over gaps with p_j<=2X gives at most
         G_X^(-1) sum_{p_j<=2X}(p_{j+1}-p_j)^2
         << X(log X)^(3-A)=o(X).
  [3] ASSUME 2<=h<=G_X:=(log X)^A for the surviving endpoints.
      BY the suffix in [1] is nonempty, so r>=1 and r<=h-1 gives h>=2,
         and removing the o(X) family from [2] gives h<=G_X.
  [4] HAVE with D_X=ceil((G_X+1)log_2(2X))+2, one has
      r<=G_X and ell<=D_X.
      BY [1], [3], every accepted factor is at least 2, and
         product_{t=u}^v d_t=n product_{t=c}^m d_t <= (2X)^(r+1).
  [5] HAVE ell>=r+2.
      BY the r suffix factors and the endpoint n are all larger than
         x=d_v, while every left factor is at most x; equality of products
         rules out ell<=r+1.
  [6] HAVE with H_0=(log X)^E, endpoints with x<=H_0 contribute o(X).
      BY then n divides an x-smooth left product and hence n is H_0-smooth;
         explicitly, the equality in [1] writes the left product as n times an
         integer suffix product, and every left factor is at most x, so every
         prime divisor of n is at most x<=H_0.  Then active_smooth_number_decay
         gives o(X) such n for fixed E.
  [7] ASSUME x>H_0.
      BY removing the o(X) family from [6].
  [8] HAVE every prime p in [w,x] with p>h is an accepted left factor whose
      prime p divides the terminal product n product_{t=c}^m d_t.
      BY p>h>=2, so every such prime p is accepted.  Since the left block is
         the consecutive accepted-index block from w=d_u to x=d_v, every
         accepted integer whose value lies in [w,x] is one of its factors.
         The product identity from [1] then makes p divide the terminal product.
  [9] HAVE [w,x] contains at most D_X-2 primes exceeding h.
      BY the terminal product has r+1 factors each at most 2X, hence at most
         ceil((r+1)log(2X)/log h) prime factors exceeding h, counted with
         multiplicity, and this is at most D_X-2 by the definition of D_X
         in [4].
  [10] HAVE unless the small-left family from [6] occurs, the D_X-th previous
       prime P_{D_X}(x) exists, is >h, and satisfies w>P_{D_X}(x).
       BY if P_{D_X}(x) does not exist, or if P_{D_X}(x)<=h, then
          pi(x)<=pi(h)+D_X+1=(log X)^{O(1)}, so Chebyshev's lower bound
          pi(t)>>t/log t gives x=(log X)^{O(1)}, contradicting [7] for
          large X.  Otherwise P_{D_X}(x)>h.  If w<=P_{D_X}(x), then the
          D_X previous primes below x, starting at P_{D_X}(x), all lie in
          [w,x] and exceed h; if x itself is prime this only adds one more.
          This contradicts [9], which gives at most D_X-2 such primes.
          Hence w>P_{D_X}(x).
  [11] HAVE endpoints with x-P_{D_X}(x)>H_0 contribute o(X).
       BY selberg_prime_rank_span_exception_count gives
          O(D_X^2 X(log X)^3/H_0) exceptional x; for each such x and ell
          there is at most one actual left block ending at x, and for each
          actual left block and r the relevant right product is n times the
          last r accepted predecessors by [1], hence is strictly increasing in n by
          actual_block_uniqueness_and_suffix_product_monotonicity, so the
          endpoint count is O(D_X G_X)*O(D_X^2 X(log X)^3/H_0).  Since
          D_X<=(log X)^(A+2), G_X=(log X)^A, and H_0=(log X)^E with
          E=30A, this is
          O(X(log X)^(4A+9-E))=O(X(log X)^(9-26A))=o(X).
  [12] HAVE every remaining endpoint has w>x-H_0.
       BY [10] and [11].
  [13] HAVE with eta_X=C_0 loglog X/log X, endpoints with
       ell/(r+1)>=1+eta_X contribute o(X).
       BY [12] gives
          (x-H_0)^ell <= product_{t=u}^v d_t <= (2X)^(r+1), hence
          x<=H_0+(2X)^(1/(1+eta_X)).  For each such integer x and each
          ell<=D_X there is at most one actual accepted left block ending at x,
          hence one fixed left product P.  For each r<=G_X, the chosen right
          side is P=n times the final length-r accepted suffix before n, and
          this right side is strictly increasing in n by
          actual_block_uniqueness_and_suffix_product_monotonicity.  Thus there
          is at most one endpoint for each fixed x,ell,r, so this family is
          bounded by
          (H_0+(2X)^(1/(1+eta_X)))D_XG_X.  Here
          H_0D_XG_X is polylogarithmic, and for large X,
          (2X)^(1/(1+eta_X))<=X/(log X)^(C_0/2).  Since
          D_XG_X<=(log X)^(2A+2) and C_0=10A, the latter contribution is
          O(X/(log X)^(3A-2))=o(X).
  [14] HAVE every remaining endpoint has
        ell=(r+1)+s with 1<=s<C_0(r+1)loglog X/log X.
       BY [5] and removal of the o(X) family from [13].
  [15] HAVE with R_X=floor(log X/(K_0 loglog X)), endpoints with r<=R_X
       contribute o(X).
       BY [5] and [12] give
          x<=H_0+(2X)^((R_X+1)/(R_X+2)).  For each such integer x and
          ell<=D_X there is at most one actual accepted left block ending at x,
          with fixed product P.  For each r<=R_X, the chosen right side is
          P=n times the final length-r accepted suffix before n and is strictly
          increasing in n by
          actual_block_uniqueness_and_suffix_product_monotonicity.  Hence there
          is at most one endpoint for each fixed x,ell,r, so the family is
          bounded by
          (H_0+(2X)^((R_X+1)/(R_X+2)))D_XR_X.  The H_0D_XR_X term is
          polylogarithmic, while
          (2X)^((R_X+1)/(R_X+2))<=X/(log X)^(K_0/2) for large X.  Since
          D_XR_X<=(log X)^(A+3) and K_0=10A, the latter contribution is
          O(X/(log X)^(4A-3))=o(X).
  [16] HAVE for the surviving endpoints,
       R_X<r<=G_X and, with c_A=1/(2K_0), b=r+1>=c_A log X/loglog X.
       BY [3] and [15] give R_X<r<=G_X.  Since
          R_X=floor(log X/(K_0 loglog X)), for all sufficiently large X one has
          r+1>R_X>=log X/(2K_0 loglog X)=c_A log X/loglog X.
  [17] HAVE for r>=2, with
        B_r=ceil((r+1)log(2X)/log(r+1))+2
        and H_r=B_r^2 r^2(log X)^4,
       unless the small-left family from [6] occurs, w>P_{B_r}(x).
       BY [8] and the terminal product has at most B_r-2 prime factors
          exceeding h, because
          (r+1)log(2X)/log h <= (r+1)log(2X)/log(r+1) and r<=h-1; the +2
          buffer absorbs the endpoint/rank convention.  If P_{B_r}(x) is
          missing or <=h then pi(x)<=pi(h)+B_r+1=(log X)^{O(1)}, so
          Chebyshev's lower bound forces x=(log X)^{O(1)}, already removed by
          [6].  Otherwise P_{B_r}(x)>h; if w<=P_{B_r}(x), then the B_r
          previous primes below x starting at P_{B_r}(x) all lie in [w,x] and
          exceed h, contradicting the at-most-(B_r-2) bound above.  Therefore
          w>P_{B_r}(x).
  [18] HAVE endpoints with x-P_{B_r}(x)>H_r, summed over R_X<r<=G_X,
       contribute o(X).
       BY [14] and selberg_prime_rank_span_exception_count gives
          O(B_r^2 X(log X)^3/H_r)=O(X/(r^2 log X)) exceptional x for fixed r;
          [14] has ell=(r+1)+s with
          1<=s<C_0(r+1)loglog X/log X.  For sufficiently large X the upper
          bound for s is below r+1, so there are at most r+1 possible ell.
          Actual-block uniqueness plus last-r suffix monotonicity give at most
          one endpoint for each fixed x, ell, r; summing O(X/(r log X)) over
          R_X<r<=G_X gives
          O(X log(G_X/R_X)/log X)=o(X).
  [19] HAVE every remaining endpoint has w>x-H_r, H_r+h<T_X, and x>H_r.
       BY [17], [18], [16], and the following fixed-power estimate.  Since
          R_X<r<=G_X=(log X)^A and
          R_X>=log X/(2K_0 loglog X) for large X, one has
          log(r+1)>=c loglog X.  Therefore
          B_r<=C(r+1)log X/log(r+1)<=C(log X)^(A+1), and hence
          H_r=B_r^2 r^2(log X)^4<=C(log X)^(4A+6).  Since
          h<=G_X=(log X)^A, this gives H_r+h<=(log X)^(4A+7) for large X.
          Because B=20A>4A+7 for A>3, H_r+h<(log X)^B=T_X.  Finally [7] and
          H_0=(log X)^E>(log X)^B=T_X, with E=30A>B, give x>H_r.
  [20] HAVE the witness can be written as
        prod_{i=1}^ell (x-a_i)=prod_{j=1}^b(q+c_j),
        where b=r+1, 0<=a_i<T_X, and 1<=c_j<=h.
       BY [1], [19], and the fact that the terminal factors are n=q+h and
          the r accepted suffix factors lying between q and n.
  [21] HAVE q^(b/ell) <= x <= H_r+(q+h)^(b/ell).
       BY the terminal product is between q^b and (q+h)^b, while the left
          product is between (x-H_r)^ell and x^ell, with x-H_r>0 by [19].
  [22] HAVE x=q^(b/ell)+O(T_X).
       BY [21], concavity gives (q+h)^(b/ell)-q^(b/ell)<=h, and
          H_r+h<T_X by [19].
  [23] HAVE 1/(log X)^B <= 1-b/ell <= B loglog X/log X.
       BY the lower bound follows from s>=1 and ell<=D_X<=(log X)^B for
          large X; the upper bound follows from [14] and B=20A>C_0.
  [24] HAVE q-x>0.
       BY [22] and [23]: write delta=1-b/ell and
          delta_0=(log X)^(-B).  From [3],
          q=n-h>=X-G_X>=X/2 for large X, and [23] gives
          delta>=delta_0.  The function
          q-q^(1-delta)=q(1-exp(-delta log q)) is increasing in delta.  Since
          delta_0 log q=log q/(log X)^B=o(1), one has
          1-exp(-delta_0 log q)>=c delta_0 log q.  Hence
          q-q^(b/ell)
            >= q(1-exp(-delta_0 log q))
            >= c X log X/(log X)^B >> T_X.  Combining this with [22] gives
          q-x>0.
  [25] HAVE the left factors x-a_i are distinct accepted terms, the terminal
       values q+c_j are distinct, and ell<=D_X<=(log X)^(A+2).
       BY [1], [4], [20], strict increase of the accepted sequence, and the
          fact that n is not yet in the accepted prefix while the suffix terms
          are accepted predecessors.
  [26] HAVE x<q<2X.
       BY [24] and q<n<=2X.
  [27] SHOW the claimed localized witness and stated tail bounds.
       BY [25], [26], and the tail removals [2], [6], [11], [13], [15],
          [18], together with the witness construction [1], [3], [4], [16],
          [20], [22], and [23].
  QED BY [27].

THEOREM nonempty_suffix_rejections_density_zero:
  STATUS: CONDITIONAL_ON_UNDISCHARGED_SELBERG_GAP_MOMENT.
  GIVEN:
    - Constants are fixed in the order
        A>3,
        C_0=10A,
        K_0=10A,
        E=30A,
        B=20A,
        D=2,
        C_smooth=A+2.
      For each dyadic shell X<n<=2X, put
        G_X=(log X)^A,
        T_X=(log X)^B,
        Y_X=exp(log X/(loglog X)^D),
        Lambda_X=ceil(log(3X)/log Y_X)+2.
  CLAIM:
    Conditional on the undischarged Selberg prime-gap second moment stated in
    the header, R_+(N)=o(N) for the canonical prefix_greedy_sequence.

PROOF OF nonempty_suffix_rejections_density_zero:
  [1] HAVE in each dyadic shell X<n<=2X, the nonempty-suffix rejected endpoints
      that are also charged to the empty-suffix family contribute o(X).
      BY this subfamily is contained in the empty-suffix family up to 2X, whose
         count is E_0(2X)=o(X) by empty_suffix_rejections_density_zero.
  [2] CONSIDER a dyadic shell X<n<=2X and a surviving localized nonempty
      witness, for a nonempty-suffix rejection not charged to the empty-suffix
      family, after the six localization tail families listed in
      localized_nonempty_witness_after_independent_tails are removed.
      BY localized_nonempty_witness_after_independent_tails applies to this
         nonempty-minus-empty subfamily.
  [3] HAVE after deleting the accepted-factor smooth family, every accepted
      left factor m_i=x-a_i in the witness has p_i=P^+(m_i)>Y_X.
      BY accepted_factor_smooth_deletion_count applied with
         D as fixed above, C=C_smooth, and L=A+2, since
         localized_nonempty_witness_after_independent_tails gives
         ell<=D_X<=(log X)^(A+2), r<=G_X, 0<=a_i<T_X, x<q<2X, and the
         right suffix is the final length-r suffix of the accepted prefix
         before n.
  [4] HAVE with Lambda_X=ceil(log(3X)/log Y_X)+2, the surviving witness
      supplies at least K_avail=floor(ell/Lambda_X^2) distinct local slab
      points with labels p_i>Y_X satisfying p_i|x-a_i and p_i|D_0+r_i.
      BY terminal_support_slab_extraction applied after [3]: the localized
         theorem gives D_0=q-x>0, 0<=a_i<T_X, 1<=c_i<=h, h<T_X, and x<q<2X,
         while Y_X>T_X+h for large X; the terminal values are distinct because
         they are the current endpoint n and the distinct accepted right-suffix
         terms before n, and the left factors are distinct accepted terms in
         the old left block.
  [5] DEFINE
        K_slab=floor(c_A log X/(32(loglog X)^(2D+2))),
      where c_A=1/(2K_0) is the length constant from
      localized_nonempty_witness_after_independent_tails.
      HAVE K_slab is a positive integer, K_slab<=K_avail, and
        K_slab loglog X=o(log X)
        and (K_slab log Y_X)/(sqrt(K_slab)log X) -> infinity.
      BY localized_nonempty_witness_after_independent_tails gives
         ell>=b>=c_A log X/loglog X, while
         Lambda_X=ceil(log(3X)/log Y_X)+2=(loglog X)^D+O(1) and hence
         Lambda_X<=2(loglog X)^D for all sufficiently large X.  Therefore
         K_avail>=c_A log X/(8(loglog X)^(2D+1)), while
         K_slab<=c_A log X/(32(loglog X)^(2D+2)), so K_slab<=K_avail and
         K_slab>=1 for large X.  Also
         K_slab loglog X=O(log X/(loglog X)^(2D+1))=o(log X), and
         because log Y_X=log X/(loglog X)^D,
         (K_slab log Y_X)/(sqrt(K_slab)log X)
           =sqrt(K_slab)/(loglog X)^D
          >= c sqrt(log X)/(loglog X)^(2D+1) -> infinity
          for some fixed c>0.
  [6] HAVE the surviving localized shell endpoints are o(X).
      BY retain the lexicographically first K_slab of the K_avail slab points
         from [4], and apply general_shifted_crt_slab_count with K=K_slab:
         the localized
         theorem gives x=q^theta+O(T_X), D_0=q-x>0,
         theta=b/(b+s) with positive b,s, and
         0<theta<1 with
         1/(log X)^B<=1-theta<=B loglog X/log X; [4] gives the distinct slab
         labels and r_i=O(T_X+(\log X)^A); [5] gives the two required K
         inequalities; and the slab parameter set has explicit subpower size:
         h has at most G_X=(log X)^A choices, theta=b/ell has at most
         D_X^2<=(log X)^(2A+4) choices because 1<=b,ell<=D_X, and K_slab is
         fixed by X and the already fixed constants.  Hence for every
         epsilon>0 this parameter set has size at most X^epsilon for all
         sufficiently large X.
  [7] HAVE for each dyadic shell X<n<=2X, the nonempty rejected endpoints in
      that shell are o(X).
      BY [1] covers the nonempty endpoints also charged to the empty-suffix
         family.  For the remaining nonempty-minus-empty endpoints, the
         localization theorem removes six explicitly listed tail families, each
         o(X) in the shell and counted without using the target density theorem.
         The accepted-factor smooth-deletion family from [3] is
         o(X/(log X)^C_smooth), hence o(X).  After removing exactly these
         families, [6] counts all surviving localized endpoints by the slab
         theorem.  A finite union of o(X) shell families is o(X).
  [8] HAVE all nonempty rejected endpoints are o(N).
      BY summing the dyadic shell estimate [7]: for every epsilon>0 choose
         X_0 after all constants are fixed and after the finite shell-error
         functions in [7] are fixed, so that every dyadic shell (X,2X] with
         X>=X_0 contributes at most epsilon X; the shells with
         X<X_0 contribute O(X_0), and the dyadic tail up to N contributes at
         most epsilon sum_{2^j<=N}2^j <= 2epsilon N.
  QED BY [8].

THEOREM prefix_greedy_rejection_density_zero:
  STATUS: CONDITIONAL_ON_UNDISCHARGED_SELBERG_GAP_MOMENT.
  CLAIM:
    Conditional on the undischarged Selberg prime-gap second moment stated in
    the header, R(N)=o(N) for the canonical prefix_greedy_sequence.

PROOF OF prefix_greedy_rejection_density_zero:
  [1] HAVE R_+(N)=o(N).
      BY nonempty_suffix_rejections_density_zero.
  [2] HAVE E_0(N)=o(N).
      BY empty_suffix_rejections_density_zero.
  [3] HAVE R(N)<=E_0(N)+R_+(N)+O(1).
      BY prefix_greedy_rejection_witness_split shows that every rejected n>=3
         has either an empty-suffix rejecting equality or a nonempty-suffix
         rejecting equality, and the O(1) term covers the manually rejected
         initial value n=1 and any finite initial cutoff.
  [4] SHOW R(N)=o(N).
      BY [1], [2], and [3].
  QED BY [4].

-- This retained route is not used by the finite-horizon proof candidate or by
-- paper/main.tex.
THEOREM erdos421_solution_conditional_selberg_route:
  STATUS: CONDITIONAL_ON_UNDISCHARGED_SELBERG_GAP_MOMENT.
  CLAIM:
    Conditional on the undischarged Selberg prime-gap second moment stated in
    the header, erdos421_target holds.

PROOF OF erdos421_solution_conditional_selberg_route:
  [1] HAVE R(N)=o(N) for prefix_greedy_sequence.
      BY prefix_greedy_rejection_density_zero.
  [2] SHOW erdos421_target holds.
      BY prefix_greedy_route_solves_erdos421 applied to [1].
  QED BY [2].

-- ---------------------------------------------------------------------------
-- Finite-horizon private-barrier route
-- ---------------------------------------------------------------------------

DEFINITION modified_private_barrier_greedy_sequence:
  A deterministic deletion set D subset N is fixed before the scan and satisfies
  1 in D, 2 notin D, and |D cap [1,N]|=o(N).
  The modified sequence rejects every n in D.  It accepts 2.  For n>=3 with
  n notin D, it accepts n iff adjoining n to the accepted prefix creates no
  equality between two distinct finite consecutive-block products.

DEFINITION modified_rejected_count:
  R_D(N) := #{n<=N : n is rejected by modified_private_barrier_greedy_sequence}.

THEOREM modified_greedy_product_uniqueness:
  GIVEN:
    - A is generated by modified_private_barrier_greedy_sequence for a fixed
      deterministic deletion set D.
  CLAIM:
    Every finite stage of A has distinct consecutive-block products.

PROOF OF modified_greedy_product_uniqueness:
  [1] HAVE the initial accepted stage A={2} has distinct consecutive-block
      products.
      BY there is only one nonempty accepted interval.
  [2] HAVE rejecting a candidate preserves distinct consecutive-block products.
      BY the accepted prefix is unchanged, whether the rejection is forced by D
         or caused by a collision.
  [3] HAVE accepting a candidate preserves distinct consecutive-block products.
      BY the modified rule accepts only after checking the enlarged prefix has
         no equality between two distinct finite consecutive-block products.
  [4] SHOW every finite stage has distinct consecutive-block products.
      BY induction over the scan using [1], [2], and [3].
  QED BY [4].

THEOREM modified_collision_rejection_witness_split:
  GIVEN:
    - n>=3 is rejected by modified_private_barrier_greedy_sequence.
    - n is not in the deterministic deletion set D.
    - d_1<...<d_m is the accepted prefix before testing n.
  CLAIM:
    There is an old consecutive accepted block product P and a suffix product
    S of the accepted prefix, possibly S=1, such that P=n*S.

PROOF OF modified_collision_rejection_witness_split:
  [1] HAVE the old accepted prefix has distinct consecutive-block products.
      BY modified_greedy_product_uniqueness.
  [2] HAVE n was rejected because adding n created a collision.
      BY n is not in D, so the modified rule rejects it only for collision.
  [3] HAVE one colliding block in the enlarged prefix contains n and the other
      is an old block.
      BY old-old collisions are impossible by [1], and new-new collisions both
         contain n as their largest value; cancelling n leaves two suffix
         products of the old prefix.  All accepted terms are at least 2 because
         1 is in D and the initial accepted term is 2, so extending a suffix
         strictly multiplies its product.  Equal suffix products therefore have
         identical suffixes.
  [4] HAVE the new block is n times an old suffix product S.
      BY n is the newest and largest accepted candidate, so any consecutive
         accepted-index block containing n ends at n and consists of n times a
         suffix of the old prefix, with the empty suffix allowed.
  [5] SHOW P=n*S for an old consecutive accepted block P.
      BY [3] and [4].
  QED BY [5].

DEFINITION modified_empty_suffix_collision_rejection:
  A rejected n is in this family if n notin D and, in some old-new collision
  witness P=n*S supplied by modified_collision_rejection_witness_split, the
  suffix product is empty, S=1.  Equivalently, n itself is an old consecutive
  accepted block product.

DEFINITION modified_nonempty_collision_rejection:
  A rejected n is in this family if n notin D and its deterministic chosen
  old-new collision witness has nonempty suffix product S>1.

DEFINITION deterministic_overlap_cancelled_nonempty_witness:
  For a nonforced modified-greedy collision rejection n that is not charged to
  the empty-suffix family, choose the lexicographically first old-new collision
  witness in accepted-index coordinates, first by old-block endpoints and then
  by suffix start.  Cancel the maximal common contiguous overlap between the
  old block and the final suffix.  The old block is not wholly contained in
  that suffix, and if cancellation exhausted the suffix then n itself would be
  an old block product, contrary to the non-empty-suffix hypothesis.  Thus the
  remaining suffix is nonempty; the resulting old-left block and final suffix
  are the chosen overlap-cancelled nonempty witness for n.

THEOREM finite_horizon_private_barrier_skeleton:
  STATUS: UNCONDITIONAL_CANDIDATE_INTERNAL_HOSTILE_AUDIT_PASSED_NOT_PROMOTED.
  GIVEN:
    - The Matomaki--Teravainen E2 theorem in the header.
    - The de Bruijn--Dickman smooth-number bound in the header.
  CLAIM:
    There are fixed constants beta=6 and N_0, a deterministic deletion set D,
    and selected semiprime barriers B such that:
      (i) |D cap [1,N]|=o(N);
      (ii) each selected barrier b=p_1p_2 has
           (log b)^1.08 < p_1 <= (log b)^1.1, p_2 prime, and a globally
           distinct private label p_2;
      (iii) every selected barrier lies outside D and is accepted by
           modified_private_barrier_greedy_sequence;
      (iv) for every sufficiently large N, with
           F_X=X^floor(sqrt(loglog X)) and X_0(N) the dyadic scale satisfying
           F_{X_0}<N<=F_{2X_0}, outside D, a finite initial segment n<N_0, and
           the explicit o(N) smooth-left family whose chosen witness has
           old-left maximum x<=5X_0(N), every nonforced nonempty collision
           rejection n<=N, with its deterministic chosen overlap-cancelled
           witness, has a previous selected barrier q_B(n)<n with
           n-q_B(n)=O((log n)^beta); the final suffix of that witness starts
           after q_B(n), and the old left block of that witness has span
           x-w=O((log n)^beta).

PROOF OF finite_horizon_private_barrier_skeleton:
  [1] LET beta=6.  Start the barrier construction only above a fixed large
      dyadic shell X_min, put 1 in D, keep 2 outside D, and absorb all other
      finite initial choices into O(1).  For a dyadic shell X<n<=2X with
      X>=X_min, put L_X=floor((log X)^beta) and L_0(X)=(log(3X))^2.1.  Partition the
      shell into full consecutive L_X-blocks and put the O(L_X)
      shell-boundary remainders into D.  In a full long block I=[U,U+L_X),
      call an integer start y admissible only when U<=y and
      y+L_0(X)<U+L_X.  Since every admissible y in the shell satisfies
      y<3X for large X, the MT interval (y,y+(log y)^2.1] remains inside I.
      BY definition; the finite initial segment is O(1), and the boundary
         remainders contribute O(L_X)=o(X) in each shell and hence density zero
         after dyadic summation.
  [2] HAVE the total length of long blocks in [X,2X] for which fewer than half
      of the admissible starts y are MT-good is O(X/(log X)^delta).
      BY a full long block has L_X-L_0(X)+O(1) admissible starts, hence
         (1+o(1))L_X admissible starts since beta=6>2.1.  If fewer than half
         are MT-good, then at least cL_X admissible starts in that block are
         MT-exceptional for a fixed c>0.  Admissible starts belong to a unique
         full long block, and the MT theorem applied up to 2X+O(L_X) gives
         O(X/(log X)^delta) exceptional integer starts after changing the
         implied constant.  Therefore the number of bad full long blocks is
         O(X/(L_X(log X)^delta)), and their total length is
         O(X/(log X)^delta).
  [3] HAVE every remaining long block contains at least
        (log X)^(beta-1-o(1))
      distinct candidate large-prime labels p_2 from the MT range.
      BY the good starts give >>L_X (log X)^1.1 start-semiprime incidences:
         every admissible good start has y in [X,2X+O(L_X)] and hence
         log y=(1+o(1))log X, so the MT lower bound
         c_0(log y)^1.1 is >=c_1(log X)^1.1.  A fixed semiprime b is counted
         only for starts y with b-L_0(X)<y<b, so for at most L_0(X)+O(1)
         admissible integer starts.  Thus the block contains at least
         >> L_X (log X)^1.1/L_0(X)=(log X)^(beta-1-o(1)) distinct semiprimes.
         By admissibility, every counted semiprime lies inside the same long
         block.  A fixed large label p_2 gives at most one product p_1p_2 inside
         a single long block: two such products with different small primes
         differ in absolute value by p_2*|p_1-p_1'|>=p_2, while
         p_2>=X/(log X)^1.1 >> L_X.  Hence the distinct semiprimes give the
         same number of distinct labels.  For
         b=p_1p_2 in
         (y,y+L_0(X)], one has log b=log y+O(L_0(X)/X).  The upper bound
         p_1<=(log y)^1.1<=(log b)^1.1 is immediate.  For the lower bound,
         (log y)^1.09-(log b)^1.08 tends to infinity, so the MT inequality
         p_1>(log y)^1.09 implies p_1>(log b)^1.08 for all sufficiently large X.
  [4] HAVE a fixed large prime label p_2 is adjacent to at most
        (log X)^(1.1+o(1))
      long blocks in the shell.
      BY p_1 must be a prime in a fixed polylogarithmic interval and, for each
         p_1, the product p_1p_2 lies in O(1) long blocks.
  [5] HAVE after forbidding labels already selected in earlier comparable
      shells, a deterministic greedy maximal block-label matching leaves
      o(X/L_X) good long blocks unmatched.
      BY order the good long blocks by increasing left endpoint, and order the
         candidate labels in a block by increasing prime label p_2, with the
         unique in-block barrier carrying p_2 as tie data.  Scanning blocks in
         that order, match the block to the first candidate label that was not
         selected in an earlier shell and has not already been matched in the
         current shell, if such a label exists; otherwise leave the block
         unmatched.  This deterministic procedure is fixed before the modified
         greedy acceptance scan and produces a maximal matching relative to the
         earlier-forbidden labels.

         An already selected label adjacent to [X,2X] must have been selected
         in polylogarithmically comparable dyadic shells, since both its old and
         current small cofactors are polylogarithmic.  More precisely, the
         current adjacency gives
           X/(log X)^1.1 <= p_2 <= 2X/(log X)^1.08,
         while an earlier selected barrier from shell [Y,2Y] with the same
         label gives
           Y/(log Y)^1.1 <= p_2 <= 2Y/(log Y)^1.08.
         These inequalities first imply Y=X^{1+o(1)}, hence log Y is
         comparable to log X.  Substituting that comparability back into the
         same inequalities, and using that the small-cofactor exponent interval
         has width 0.02, gives the safe wider window
           c X/(log X)^0.05 <= Y <= C X(log X)^0.05
         for fixed c,C and all large X.  Hence only O(loglog X) earlier dyadic
         shells contribute, and their total selected-label count is
         O((X/L_X)(log X)^0.06): each such shell contributes
         O(Y/(log Y)^beta) labels, the largest Y in the safe window contributes
         O((X/L_X)(log X)^0.05), and the O(loglog X) dyadic-shell factor is
         absorbed into (log X)^0.01.  In the current shell there are at most
         O(X/L_X) matched labels, which is absorbed by the same bound.  If U good
         blocks remain unmatched, every one of their
         M_X>=(log X)^(beta-1-o(1)) labels is already forbidden by an earlier
         shell or matched in the current shell, and every such label is adjacent
         to at most D_X=(log X)^(1.1+o(1)) of these U blocks.  Hence
         U M_X <= O((X/L_X)(log X)^0.06)D_X, so
         U=O((X/L_X)(log X)^(-(beta-2.16)+o(1)))=o(X/L_X),
         because beta=6.
  [6] HAVE after selecting one matched barrier in each matched good long block,
      with its matched large prime p_2 as label, and after deleting every
      MT-bad long block, every unmatched good long block, and the nonbarrier
      prefix before the selected barrier in the first matched block after each
      maximal deleted run and in the first matched block after the shell's left
      boundary, these block and prefix deletions have total size
        O(X/(log X)^delta)+O(X(log X)^(-(beta-2.16)+o(1)))+O(L_X)=o(X)
      in the shell.
      BY [2] contributes O(X/(log X)^delta), and [5] contributes
         o(X/L_X) blocks times L_X.  The number of maximal deleted runs is at
         most the number of deleted long blocks plus one, and the shell-left
         boundary contributes at most one further prefix.  Each extra prefix
         deletion in the next matched block has length at most L_X and protects
         the selected barrier itself.  More explicitly, the number of bad
         blocks is O(X/(L_X(log X)^delta)) by [2], while the number of
         unmatched good blocks is
         O((X/L_X)(log X)^(-(beta-2.16)+o(1))) by [5].  Multiplying the
         resulting deleted-run count by L_X gives the displayed bound; since
         beta=6 and delta>0 are fixed, it is o(X).
  [7] LET the finite horizon for selected barriers in shell X<n<=2X be
        C_X=floor(sqrt(loglog X)),  F_X=X^C_X.
      Delete every multiple m!=b of the selected label p_2 with m<=F_X.
      HAVE these horizon deletions have density zero:
        |D_hor cap [1,N]|=o(N).
      BY labels selected in [X,2X] are >=X/(log X)^1.1 and there are O(X/L_X)
         of them.  By a union bound over selected shell-label pairs, overlaps
         between arithmetic progressions only reduce the actual deletion count,
         and excluding the protected barrier b only reduces it.  Thus the
         contribution of this shell to D_hor cap [1,N] is at most
           O(min(N,F_X)/(log X)^(beta-1.1)).
         Put s=beta-1.1>1.

         First sum over dyadic shells X<=N.  Let X_0 be the largest dyadic
         shell with F_X<N, if it exists; finite initial failures are absorbed
         into O(1).  On old shells F_X<N, the summands are F_X/(log X)^s.
         Since log F_X=floor(sqrt(loglog X))log X, passing from X to 2X
         multiplies F_X by at least 2^(0.5sqrt(loglog X)) for all large X:
         the integer C_X=floor(sqrt(loglog X)) is nondecreasing, so
         F_{2X}/F_X=(2X)^(C_{2X})/X^(C_X)
           >=2^(C_X)>=2^(0.5sqrt(loglog X)) eventually.
         Hence the old-shell geometric tail is dominated by its final shell and
         is O(F_{X_0}/(log X_0)^s)<=O(N/(log X_0)^s).  On recent shells
         X_0<X<=N, the sum is
           N sum_{X_0<X<=N, dyadic} 1/(log X)^s
           = O(N/(log X_0)^(s-1)),
         by comparison with the integral of t^(-s) over
         log X_0<=t<=log N.  From F_{X_0}<N<=F_{2X_0} one has
         log X_0 >= (1+o(1))log N/sqrt(loglog N), so both old and recent
         shell sums are o(N).

         Future shells X>N can affect [1,N] only when some selected label
         p_2<=N.  Because p_2>=X/(log X)^1.1 and t/(log t)^1.1 is increasing
         for large t, this forces X<=N(log N)^2 for all large N: otherwise
         the lower bound at X=N(log N)^2 is already
         N(log N)^2/(log(N(log N)^2))^1.1>N.  There are O(loglog N) such dyadic
         shells, log X is comparable to log N throughout them, and each shell
         contributes O(N/(log N)^s).  The future-shell tail is therefore
         O(N loglog N/(log N)^s)=o(N).
  [8] HAVE |D cap [1,N]|=o(N).
      BY D is the union of the finite initial choices from [1],
         shell-boundary remainders from [1], block and prefix deletions from [6]
         over all dyadic shells, and horizon deletions from [7].  Boundary
         remainders contribute O(L_X) per shell, so their dyadic sum up to N is
         O((log N)^(beta+1))=o(N).  The MT-bad part of [6] contributes
         O(X/(log X)^delta) per shell, whose dyadic sum is
         O(N/(log N)^delta)=o(N).  The unmatched-block and prefix part of [6]
         contributes O(X(log X)^(-(beta-2.16)+o(1))) per shell; because
         beta=6, this is bounded by O(X/(log X)^3) for all sufficiently large
         shells, and its dyadic sum is o(N).  The finite initial segment is
         O(1), and the horizon-deletion estimate in [7] handles the remaining
         deterministic deletions.
  [9] HAVE each selected barrier lies outside D and is accepted.
      BY the selected barrier lies in a matched long block not marked for block
         deletion, and it is protected from its own label deletion.  It is not
         deleted by any other selected label: if a different selected label p
         divides b=p_1p_2 and b<=F_Y for the shell [Y,2Y] that selected p, then
         p is either p_1 or p_2.  The case p=p_2 is excluded by global label
         uniqueness.  The case p=p_1 is impossible for large Y because
         p>=Y/(log Y)^1.1 while p_1<=log(b)^1.1<=log(F_Y)^1.1
         =(C_Y log Y)^1.1=o(Y/(log Y)^1.1).  Thus b is not in D.
         When b is scanned, every earlier multiple of p_2 is a deterministic
         deletion because b<=2X<F_X for large X.  Thus no old accepted product
         is divisible by p_2: if the prime p_2 divided a product of old accepted
         factors, it would divide one old accepted factor, which would be an
         earlier multiple of p_2 and hence would lie in D.  Every new product
         containing b is divisible by p_2, so no old product can equal a new
         product containing b.  Old-old collisions are impossible by the greedy
         induction.  Two new products containing b cannot collide either:
         cancelling b would equate two final suffix products of the old accepted
         prefix, and distinct final suffixes are strictly ordered by inclusion,
         with each extension multiplying by an accepted term at least 2.  Hence
         b cannot be collision-rejected.
  [10] HAVE barrier blocking: if a nondeleted nonforced collision rejection
       n<=N has a surviving overlap-cancelled witness
       old_left_product = n*(final_suffix_product), with the old left block
       strictly before the final suffix, and if that old left block contains a
       selected barrier b=p_1p_2 from shell [X,2X] with N<=F_X, then no such
       surviving witness exists.
       BY p_2 divides the old left product.  The product identity forces p_2 to
          divide the right product.  Since p_2 is prime, it divides one
          terminal factor on the right, meaning either the endpoint n or one
          accepted factor in the final suffix.  That terminal factor is not b
          because the overlap-cancelled right block is strictly to the right of
          the old left block and n>b.  It is also not any selected barrier.  If
          a selected barrier c=r_1r_2 with c<=F_X were divisible by p_2, then
          p_2 would be either its private label r_2 or its small factor r_1.
          The first case is excluded by global label uniqueness from [5].  The
          second is impossible for large X because
          r_1<=(log c)^1.1<=(log F_X)^1.1=(C_X log X)^1.1
          =o(X/(log X)^1.1)<=p_2.  The terminal factor is at most n<=N, hence
          at most F_X, and is therefore a nonbarrier multiple of p_2.  Thus it
          lies in D by the finite-horizon deletion rule.  If it is n, this
          contradicts that the collision rejection under discussion is
          nondeleted; if it is a suffix factor, this contradicts that suffix
          factors are accepted and D is forcibly rejected.
  [11] HAVE every nondeleted integer y>=N_0 that is not itself a selected
       barrier has a previous selected barrier q_B(y)<y with
       y-q_B(y)=O((log y)^beta).
       BY y lies in a matched long block above the finite initial construction
          range, because shell-boundary remainders,
          bad blocks, and unmatched blocks are deleted.  Let I be this matched
          block and let b_I be its selected barrier.  If y>b_I, use b_I; then
          y-b_I<L_X.  If y<b_I, then y lies in the nonbarrier prefix of I
          before its selected barrier.  Because y is nondeleted, I cannot be the
          first matched block after a maximal deleted run, and cannot be the
          first matched block after the shell's left boundary; those prefixes
          were put into D in [6].  Therefore the preceding full long block
          exists in the same shell and was not deleted.  Since the only
          undeleted full long blocks are matched good blocks, that preceding
          block contains a selected barrier b' below y.  The distance from y to
          b' is less than two long-block lengths, so y-b'=O(L_X)=O((log y)^beta).
  [12] HAVE the final suffix in any surviving nonempty overlap-cancelled
       collision witness starts after q_B(n), and hence has length
       r=O((log n)^beta).
       BY n is not itself a selected barrier, since selected barriers are
          accepted by [9]; after absorbing n<N_0 into the finite initial
          segment, [11] gives q_B(n)<n.  If the final suffix contained a
          selected barrier b=p_1p_2 from shell [X_b,2X_b], then the old left
          block lies before b after overlap cancellation.  Every old-left
          factor is <b<=2X_b<F_{X_b} for large X_b.  No old-left factor that is
          itself a selected barrier can be divisible by b's private label: the
          same-label case is excluded by global uniqueness, while using b's
          label as that selected barrier's small factor is impossible since
          every such old-left factor m<2X_b has small factor at most
          (log m)^1.1=o(X_b/(log X_b)^1.1)<=p_2.  Hence any old-left factor
          divisible by b's private label would be an earlier nonbarrier
          multiple of that label inside its finite horizon and would lie in D.
          No accepted old-left factor can do this, so the old product is not
          divisible by the label while the right product is, contradiction.
          Thus the final suffix contains no selected barrier.  If the final
          suffix began at or before q_B(n) in accepted-index order, it would
          contain the accepted selected barrier q_B(n), again impossible.  Therefore
          the final suffix is contained in the accepted terms after q_B(n),
          whose values are in an interval of length O((log n)^beta) by [11].
  [13] FOR all sufficiently large N, LET X_0(N) be chosen so that
       F_{X_0}<N<=F_{2X_0}; absorb smaller N into the finite initial segment.
       HAVE endpoints whose
       chosen nonempty overlap-cancelled witness has old left maximum
       x<=5X_0(N) contribute o(N).
       BY n divides the old left product, and all prime factors of that product
          are <=x; hence n is 5X_0(N)-smooth.  The inverse-horizon definition
          gives
            u_N:=log N/log(5X_0(N))=(1+o(1))sqrt(loglog N),
          so u_N tends to infinity and lies in the stated uniform
          O(sqrt(loglog N)) range.  The de Bruijn--Dickman bound gives o(N).
  [14] HAVE every remaining surviving nonempty overlap-cancelled collision
       witness has old-left span x-w=O((log n)^beta).
       BY if x is itself a selected barrier, then [10] contradicts survival
          because x>5X_0(N) after [13], so the dyadic shell lower endpoint of
          x is above 2X_0(N), and hence its horizon is at least
          F_{2X_0}>=N by the dyadic monotonicity of F_X proved in [7].
          Otherwise, for x>5X_0(N), the previous selected barrier
          b_x below x given by [11] lies above 4X_0(N) for large N, because the
          barrier gap is fixed-polylogarithmic and fixed powers of log x are
          o(X_0(N)) on this range.  Therefore the dyadic shell lower endpoint
          of b_x is above 2X_0(N), so its horizon is at least F_{2X_0}>=N by
          the same dyadic monotonicity.  The barrier b_x lies within
          O((log x)^beta) of x by [11].  If the old left block began at or
          before b_x, then because the old block is a consecutive accepted
          block ending at x and b_x is an accepted term between its endpoints,
          that block would contain b_x; [10] would contradict survival.  Thus
          w lies after b_x.
  [15] SHOW properties (i)--(iv).
       BY [8] gives (i); [3] gives the small-cofactor bounds in (ii) and [5]
          gives global distinctness of private labels; [9] gives (iii).  For
         (iv), fix N and a nondeleted nonforced nonempty collision rejection
          with its chosen overlap-cancelled witness.  Since selected
          barriers are accepted by [9], the rejected endpoint is not itself a
          selected barrier, so [11] gives q_B(n)<n and the polylogarithmic gap.
          Step [12] gives the final-suffix conclusion for that chosen nonempty
          witness.  Step [13] removes an o(N) smooth-left family depending only
          on the chosen witness's old left maximum, and [14] gives the old-left
          span for all remaining chosen witnesses.
  QED BY [15].

THEOREM finite_horizon_localized_nonempty_witness:
  STATUS: UNCONDITIONAL_CANDIDATE_INTERNAL_HOSTILE_AUDIT_PASSED_NOT_PROMOTED.
  GIVEN:
    - The finite_horizon_private_barrier_skeleton is available.
    - X is sufficiently large and X<n<=2X.
    - n is a collision rejection of modified_private_barrier_greedy_sequence
      not in the deterministic deletion set and not charged to the empty-suffix
      family.
  CLAIM:
    Outside o(X) shell endpoints, the chosen overlap-cancelled nonempty witness
    has the localized form
      prod_{i=1}^ell (x-a_i)=prod_{j=1}^b(q+c_j),
    with q=q_B(n), n=q+h, 2<=h<=(log X)^7, 0<=a_i<T_X,
    1<=c_j<=h, T_X=(log X)^B for fixed B, b=r+1, ell=b+s, s>=1,
    r<=G_X=(log X)^7, ell<=D_X:=ceil((G_X+1)log_2(2X))+2,
    the left factors x-a_i are distinct accepted terms, the terminal values
    q+c_j are distinct, and they are exactly n=q+h together with the actual
    final length-r suffix before n,
    b>=c log X/loglog X for a fixed c>0,
    x=q^(b/ell)+O(T_X),
    1/(log X)^B <= 1-b/ell <= B loglog X/log X,
    and x<q<2X.

PROOF OF finite_horizon_localized_nonempty_witness:
  [1] HAVE the deterministic chosen overlap-cancelled witness
        product_{t=u}^v d_t = n product_{t=c}^m d_t
      with v<c<=m, old left maximum x=d_v, old left minimum w=d_u, and final
      suffix length r=m-c+1.
      BY modified_collision_rejection_witness_split gives an old block equal to
         n times a suffix of the old accepted prefix.  The old block cannot be
         wholly contained in that suffix, since then the old product is at most
         the suffix product and is strictly smaller than n times that suffix
         product.  If the old block overlaps the suffix from the left, cancel
         the common contiguous accepted factors.  If this cancellation exhausts
         the suffix, the endpoint has an empty-suffix old-product witness,
         contrary to the hypothesis that it is not charged to the empty-suffix
         family.  Otherwise the remaining suffix is nonempty and final, and the
         remaining old block lies strictly to its left; write it as [u,v] and
         write the remaining final suffix as [c,m].
  [2] HAVE, outside o(X) shell endpoints, with q=q_B(n) and h=n-q,
      2<=h<=G_X=(log X)^7, r<=G_X, x-w<=H_X=(log X)^7, and x>H_X.
      BY finite_horizon_private_barrier_skeleton gives the previous barrier
         gap bound h=O((log n)^6), the final-suffix bound, and the old-left span
         bound, all of which are <=(log X)^7 for all sufficiently large X.
         Since the remaining suffix is nonempty and starts after q, there is an
         accepted integer strictly between q and n, so h>=2.  Deterministic
         deletions contribute o(X) in this shell because
         |D cap (X,2X]|<=|D cap [1,2X]|=o(X).  The smooth-left family from the
         skeleton contributes o(X) in this shell after applying its global
         o(N) estimate with N=2X.  In the shell X<n<=2X, apply the smooth-left
         removal with ambient endpoint bound 2X; the remaining endpoints have
         x>5X_0(2X).  Since
         X_0(2X)=(2X)^(1/((1+o(1))sqrt(loglog X))) on the inverse-horizon
         scale, 5X_0(2X) dominates every fixed power of log X, hence x>H_X for
         all sufficiently large X.
  [3] HAVE ell<=D_X:=ceil((G_X+1)log_2(2X))+2 and ell>=r+2.
      BY the terminal side has r+1 factors each <=2X, each accepted factor is
         at least 2, and 2^ell <= (2X)^(r+1).  The overlap-cancelled old left
         block lies strictly before the final suffix, while n is the current
         endpoint; hence every terminal factor is larger than every old-left
         factor.  If ell<=r+1, the terminal product is strictly larger than the
         old product, contradicting equality.  Therefore ell>=r+2.
  [4] HAVE endpoints with ell/(r+1)>=1+C_0 loglog X/log X, where C_0=60,
      contribute o(X).
      BY [2] gives (x-H_X)^ell <= (2X)^(r+1).  Thus
         x<=H_X+(2X)^(1/(1+C_0 loglog X/log X)).
         For each fixed accepted endpoint x and length ell, the actual old
         left block ending at x is unique and has a fixed product P.  For fixed
         r, any endpoint counted with this old block must satisfy
           P=n*(product of the last r accepted predecessors before n),
         and the right side is strictly increasing in n by
         actual_block_uniqueness_and_suffix_product_monotonicity.  Hence there
         is at most one endpoint for each fixed x,ell,r.  Multiplying the
         admissible x-count by D_X possible ell values and G_X possible r values
         gives O(X/(log X)^20)=o(X): indeed
         (2X)^(1/(1+C_0 loglog X/log X))<=X/(log X)^40 for all sufficiently
         large X, while H_X is polylogarithmic and
         D_XG_X<=C(log X)^15.
  [5] HAVE endpoints with r<=R_X=floor(log X/(60 loglog X)) contribute o(X).
      BY [2] gives x<=H_X+(2X)^((R_X+1)/(R_X+2)).  For each fixed x,ell,r
         the same fixed-product and strict-monotonicity argument from [4] gives
         at most one endpoint.  Multiplication by D_X possible ell values and
         R_X possible r values gives O(X/(log X)^20)=o(X).  To see the saving,
         R_X+2<=log X/(50loglog X) for all sufficiently large X, so
         (2X)^(1/(R_X+2))>=(log X)^50; hence
         (2X)^((R_X+1)/(R_X+2))<=(2X)/(log X)^50.  Also
         D_XR_X<=C(log X)^9, and H_XD_XR_X is polylogarithmic.
  [6] HAVE for the remaining endpoints, b=r+1>=c log X/loglog X and
      ell=b+s with 1<=s<C_0 b loglog X/log X.
      BY [3], [4], and [5].
  [7] HAVE the surviving witness can be written as
        prod_{i=1}^ell (x-a_i)=prod_{j=1}^b(q+c_j),
      where q=q_B(n), n=q+h, 1<=c_j<=h, 0<=a_i<T_X, the left factors
      x-a_i are distinct accepted terms, the terminal values q+c_j are
      distinct, and n=q+h is one of the terminal values.
      BY [2] gives x-w<=H_X and 2<=h=n-q<=G_X; choose B>20 so
         T_X=(log X)^B dominates H_X+G_X.  The final suffix starts after q by
         finite_horizon_private_barrier_skeleton.  The old left block is a
         block of distinct accepted terms ending at x, while the terminal side
         consists of the distinct final-suffix accepted terms together with the
         current endpoint n.
  [8] HAVE x=q^(b/ell)+O(T_X).
      BY the terminal product is between q^b and (q+h)^b, while the old product
         is between (x-H_X)^ell and x^ell.  Since h+H_X<T_X and b/ell<1,
         this gives q^(b/ell)<=x<=H_X+(q+h)^(b/ell).  Since
         q=n-h>=X-G_X>1 for all sufficiently large X, the function t^(b/ell)
         is increasing and concave on the interval [q,q+h], and its derivative
         there is at most 1 because 0<b/ell<1; therefore
         (q+h)^(b/ell)-q^(b/ell)<=h.  Hence
         x=q^(b/ell)+O(H_X+h)=q^(b/ell)+O(T_X).
  [9] HAVE 1/(log X)^B <= 1-b/ell <= B loglog X/log X.
      BY the lower bound follows from s>=1 and ell<=D_X<=(log X)^B for large
         X; the upper bound follows from [6] after increasing fixed B.
  [10] HAVE x<q<2X.
       BY q<n<=2X.  For x<q, use [8] and [9]:
          writing delta=1-b/ell and delta_0=(log X)^(-B), one has
          delta>=delta_0 and q>=X-G_X>=X/2.  The function
          q(1-exp(-delta log q)) is increasing in delta, and
          delta_0 log q=o(1), so
            q-q^(b/ell) >= q(1-exp(-delta_0 log q))
              >= c' X log X/(log X)^B >> T_X.
          The last domination holds because T_X=(log X)^B is fixed
          polylogarithmic while X/(log X)^(B-1) is super-polynomial in log X.
          Combining this with x=q^(b/ell)+O(T_X) gives q-x>0.
  [11] SHOW the localized witness and all stated bounds.
       BY [6], [7], [8], [9], and [10], after removing the o(X) families in
          [2], [4], and [5].
  QED BY [11].

THEOREM finite_horizon_nonempty_rejections_density_zero:
  STATUS: UNCONDITIONAL_CANDIDATE_INTERNAL_HOSTILE_AUDIT_PASSED_NOT_PROMOTED.
  CLAIM:
    For the modified_private_barrier_greedy_sequence using the deterministic
    deletion set from finite_horizon_private_barrier_skeleton, the number of
    nonempty collision rejections n<=N is o(N).

PROOF OF finite_horizon_nonempty_rejections_density_zero:
  [1] CONSIDER a dyadic shell X<n<=2X and remove the deterministic deletion set,
      modified_empty_suffix_collision_rejection endpoints, and the o(X)
      exceptional families from finite_horizon_private_barrier_skeleton and
      finite_horizon_localized_nonempty_witness.
      BY finite_horizon_private_barrier_skeleton gives density-zero
         deterministic deletions, hence
         |D cap (X,2X]|<=|D cap [1,2X]|=o(X).  A
         modified_empty_suffix_collision_rejection endpoint n is itself an old
         consecutive accepted block product.  Since n is not already accepted,
         the old block has length at least two, so these endpoints in the shell
         are contained in the length-at-least-two block-product value set of
         the modified accepted sequence below 2X, which has size o(X) by
         length_at_least_two_block_products_sparse with ambient bound 2X.  The
         localization theorem and the private-barrier skeleton list their
         exceptional families independently of the target density theorem; a
         family proved globally o(N) contributes o(X) in this shell by applying
         its global estimate with ambient N=2X, and a family proved directly as
         a shell estimate already contributes o(X).
  [2] HAVE every remaining endpoint has the localized witness of
      finite_horizon_localized_nonempty_witness with fixed-polylogarithmic
      G_X,T_X,D_X and x<q<2X.
      BY finite_horizon_localized_nonempty_witness.
  [3] HAVE after removing the accepted-factor smooth family, the chosen prime labels
      p_i=P^+(x-a_i)>Y_X with Y_X=exp(log X/(loglog X)^2).
      BY accepted_factor_smooth_deletion_count applies to the modified accepted
         sequence as it uses only actual-block uniqueness, final-suffix
         product monotonicity, the localized witness bounds, and
         active_smooth_number_decay for this fixed subexponential cutoff.  The
         hypotheses hold with fixed constants A=7, D=2 for the subexponential
         smooth cutoff, C chosen larger than any later fixed polylogarithmic
         expansion, and some fixed L>8:
         finite_horizon_localized_nonempty_witness gives final suffix length
         r<=G_X=(log X)^7, left length
         ell<=D_X=O((log X)^8)<=(log X)^L, 0<=a_i<T_X, x<q<2X, and the right
         suffix is the final length-r suffix of the accepted prefix before n.
  [4] HAVE the surviving endpoint supplies at least K_slab distinct local slab
      points with labels p_i>Y_X satisfying p_i|x-a_i and p_i|D_0+r_i, where
      D_0=q-x and K_slab=floor(c log X/(100(loglog X)^5)).
      BY let Lambda_X=ceil(log(3X)/log Y_X)+2=(loglog X)^2+O(1).
         The finite-horizon localized witness gives distinct accepted left
         factors, distinct terminal values with n=q+h included, D_0=q-x>0,
         0<=a_i<T_X, 1<=c_j<=h, and x<q<2X.  Also T_X+h<Y_X for large X,
         h<T_X because h<=(log X)^7 and T_X=(log X)^B with fixed B>7, and
         the localized bounds give a_i+c_j<T_X+h from 0<=a_i<T_X and
         1<=c_j<=h.  Step [3]
         gives chosen labels p_i=P^+(x-a_i)>Y_X.  Thus
         terminal_support_slab_extraction gives at least
         floor(ell/Lambda_X^2) slab points with distinct r_i and distinct
         labels.  Since
         ell>=b>=c log X/loglog X and Lambda_X<=2(loglog X)^2 for large X,
         one has
           ell/Lambda_X^2 >= c log X/(4(loglog X)^5).
         This lower bound has a fixed factor-25 margin over
           c log X/(100(loglog X)^5);
         hence for all sufficiently large X,
           ell/Lambda_X^2 - 1 >= c log X/(100(loglog X)^5) >= K_slab.
         Hence floor(ell/Lambda_X^2)>=K_slab.
  [5] HAVE the surviving shell endpoints are o(X).
      BY for each endpoint retain the lexicographically first K_slab extracted
         slab points in the ordered coordinate-label list; the slab theorem
         counts all retained coordinate K-sets and therefore safely overcounts
         this deterministic choice.  Retaining a subset preserves distinct
         labels and the two divisibilities.  The retained points still have
         0<=a_i<T_X and
         r_i=a_i+c_i<T_X+h=O(T_X+(\log X)^7), so they satisfy the local
         coordinate bounds required by the slab theorem with A=7.  Apply the
         slab theorem with constants A=7, D=2 for the cutoff exponent, and with
         B equal to the fixed localization exponent from
         finite_horizon_localized_nonempty_witness, enlarged if necessary to
         dominate all fixed O-constants.  Its localized
         data hypotheses hold because [2] gives
         n=q+h, h<=(log X)^7, x=q^(b/ell)+O(T_X), D_0=q-x>0, and
         1/(log X)^B<=1-b/ell<=B loglog X/log X.  Here
         theta=b/ell, 0<theta<1, and Y_X=exp(log X/(loglog X)^2).

         The parameter tuple required there is determined by h, the pair
         (b,ell) representing theta=b/ell, and the single prescribed value
         K=K_slab.  The bounds h<=(log X)^7 and
         1<=b,ell<=D_X=O((log X)^8) give at most O((log X)^23) such tuples.
         Therefore, for every epsilon>0, the tuple set has size at most
         X^epsilon for all sufficiently large X.
         Since K_slab=floor(c log X/(100(loglog X)^5)), K_slab is positive
         for all sufficiently large X; more precisely
         K_slab>=c log X/(200(loglog X)^5) eventually.  Hence
         K_slab loglog X=O(log X/(loglog X)^4)=o(log X).  Also
         log Y_X=log X/(loglog X)^2, so
         (K_slab log Y_X)/(sqrt(K_slab)log X)
           =sqrt(K_slab)/(loglog X)^2
          >= c' sqrt(log X)/(loglog X)^(9/2) -> infinity
          for some fixed c'>0.
  [6] HAVE the dyadic shell estimates sum to o(N).
      BY step [5] counts the endpoints that survive all removals in [1] and
         [3].  Add back the removed families: deterministic deletions have
         global count o(N) by finite_horizon_private_barrier_skeleton, and so
         o(X) in (X,2X].  Modified_empty_suffix_collision_rejection endpoints
         below 2X are contained in the length-at-least-two block-product value
         set of the modified accepted sequence below 2X, hence contribute o(X)
         in the shell.  The localization and private-barrier exceptional
         families are o(N) globally or o(X) per shell by their proofs, with no
         use of finite_horizon_nonempty_rejections_density_zero.  The
         accepted-factor smooth family is o(X) in the shell by [3].  Therefore
         each dyadic shell has total nonempty collision endpoint count o(X).
         Equivalently, if f_j is the ratio of the total counted endpoints in
         the dyadic shell (2^j,2^(j+1)] to 2^j, then f_j->0 after all constants,
         deterministic choices, and exceptional functions are fixed.  For every
         epsilon>0 choose J_0 such that f_j<=epsilon for j>=J_0.  The finitely
         many shells below 2^J_0 contribute O(2^J_0), and the dyadic tail up to
         N contributes at most epsilon sum_{2^j<=N}2^j <=2epsilon N.
  [7] SHOW the nonempty collision rejections are o(N).
      BY [1]--[6].
  QED BY [7].

THEOREM erdos421_solution_finite_horizon_candidate:
  STATUS: UNCONDITIONAL_PROOF_CANDIDATE_INTERNAL_HOSTILE_AUDIT_PASSED_NOT_PROMOTED.
  CLAIM:
    Assuming the MT E2 theorem, CCDN affine-curve theorem, Mignotte factor
    inequality, elementary algebraic and prime-counting inputs, and the
    de Bruijn--Dickman smooth-number bound stated in the header,
    erdos421_target holds.

PROOF OF erdos421_solution_finite_horizon_candidate:
  [1] HAVE the deterministic deletion set D has density zero.
      BY finite_horizon_private_barrier_skeleton.
  [2] HAVE forced deletions contribute o(N) rejected values.
      BY [1].
  [3] HAVE empty-suffix collision rejections contribute o(N).
      BY every empty-suffix collision value is a length-at-least-two block
         product of the modified accepted sequence, and
         length_at_least_two_block_products_sparse applies because the sequence
         starts at 2 and is strictly increasing.
  [4] HAVE nonempty collision rejections contribute o(N).
      BY finite_horizon_nonempty_rejections_density_zero.
  [5] HAVE the accepted set of modified_private_barrier_greedy_sequence has
      natural density one.
      BY if a rejected n lies in D, it is counted by the forced family [2].
         Otherwise n notin D, and modified_collision_rejection_witness_split
         supplies at least one old-new witness P=n*S.  If any supplied witness
         has S=1, then n is a modified_empty_suffix_collision_rejection and is
         counted by [3].  If no supplied witness has S=1, the deterministic
         witness specified in deterministic_overlap_cancelled_nonempty_witness
         has S>1 and n is counted by the nonempty family [4].  Thus every
         rejection lies in the union of the forced, empty-suffix, and nonempty
         families; disjointness is not required, and all three union members are
         o(N) by [2], [3], and [4].
  [6] HAVE the accepted sequence has distinct consecutive-block products.
      BY modified_greedy_product_uniqueness.
  [7] SHOW erdos421_target holds.
      BY [5], [6], and the definition of erdos421_target.
  QED BY [7].
